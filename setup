$b1.Add_Click({
    [System.Media.SystemSounds]::Asterisk.Play()
    $b1.Enabled=$false; $b1.Text="  Working..."
    Run-Debloat; Run-EssentialTweaks
    $b1.Text="  SYSTEM SANITIZE — Debloat + Essential Tweaks"; $b1.Enabled=$true
})

$b2.Add_Click({
    [System.Media.SystemSounds]::Asterisk.Play()
    $b2.Enabled=$false; $b2.Text="  Working..."
    $manufacturer=(Get-CimInstance Win32_ComputerSystem).Manufacturer
    Write-ToUI "Detected manufacturer: $manufacturer" "Cyan"
    $vendor="Unknown"
    if($manufacturer -match "HP|Hewlett"){$vendor="HP"}
    elseif($manufacturer -match "Dell"){$vendor="Dell"}
    elseif($manufacturer -match "Lenovo"){$vendor="Lenovo"}
    elseif($manufacturer -match "Acer"){$vendor="Acer"}
    elseif($manufacturer -match "ASUS"){$vendor="ASUS"}
    elseif($manufacturer -match "MSI"){$vendor="MSI"}
    elseif($manufacturer -match "Toshiba"){$vendor="Toshiba"}
    elseif($manufacturer -match "Samsung"){$vendor="Samsung"}
    elseif($manufacturer -match "Microsoft"){$vendor="Microsoft"}
    else{Write-ToUI "Unknown system — skipping vendor bloat." "Orange"
         $b2.Text="  VENDOR PURGE — Auto-detect + Remove Vendor Bloat"; $b2.Enabled=$true; return}

    Write-ToUI "Running $vendor bloatware removal..." "Yellow"

    $vendorBloat=@{
        "HP"=@("HP.HPSupportAssistant","HP.HPQuickDrop","HP.HPPrivacySettings","HP.HPConnectionOptimizer","HP.HPSmart","HP.HPAudioCenter","HP.HPSystemEventUtility","HP.HPEnhance","HP.HPPCHardwareDiagnosticsWindows")
        "Dell"=@("Dell.DellSupportAssistforPCs","Dell.DellOptimizer","Dell.DellDigitalDelivery","Dell.DellUpdate","Dell.DellCommandUpdate","Dell.DellPowerManager","Dell.DellCinemaGuide","Dell.DellMobileConnect","Dell.DellCinema")
        "Lenovo"=@("E046963F.LenovoCompanion","E046963F.LenovoSettings","E0469640.LenovoUtility","E046963F.LenovoSettingsforEnterprise","LenovoCorporation.LenovoSettings","LenovoCorporation.LenovoID","LenovoCorporation.LenovoCompanion")
        "Acer"=@("AcerIncorporated.AcerRegistration","AcerIncorporated.QuickAccess","AcerIncorporated.UserExperienceImprovementProgram","AcerIncorporated.AcerCollection","AcerIncorporated.AcerCareCenterS","AcerIncorporated.AcerJumpStart")
        "ASUS"=@("ASUSTeKCOMPUTERINC.GlideXperience","ASUSTeKCOMPUTERINC.ASUSPCAssistant","ASUSTeKCOMPUTERINC.MyASUS","ASUSTeKCOMPUTERINC.ASUSProductRegistrationProgram","ASUSTeKCOMPUTERINC.ASUSWelcome","ASUSTeKCOMPUTERINC.ASUSLiveUpdate")
        "MSI"=@("MSI.CenterFacade","MSI.DragonCenter","MSI.MSICenter","MSI.MSICenterSDK")
        "Toshiba"=@("ToshibaCorporation.ToshibaServiceStation","ToshibaCorporation.SettingsforYourTOSHIBA")
        "Samsung"=@("HONHAIPREC.Samsung_Update","HONHAIPREC.SamsungUpdate")
        "Microsoft"=@("Microsoft.SurfaceHub","Microsoft.PPIProjection")
    }
    $vendorWinget=@{
        "HP"=@("HP.HPSupportAssistant","HP.HPQuickDrop","HP.HPPrivacySettings","HP.HPConnectionOptimizer","HP.HPSmart")
        "Dell"=@("Dell.CommandUpdate","Dell.DellOptimizer","Dell.DellSupportAssist","Dell.DellDigitalDelivery","Dell.DellPowerManager")
        "Lenovo"=@("Lenovo.SystemUpdate","Lenovo.VantageService","Lenovo.SmartAppearance")
        "Acer"=@("Acer.AcerCollection","Acer.QuickAccess")
        "ASUS"=@();"MSI"=@();"Toshiba"=@();"Samsung"=@();"Microsoft"=@()
    }

    if($vendorBloat.ContainsKey($vendor)){
        foreach($app in $vendorBloat[$vendor]){
            Write-ToUI "Checking AppX: $app"
            Get-AppxPackage -AllUsers -Name $app -ErrorAction SilentlyContinue|ForEach-Object{
                Write-ToUI "  Removing: $($_.Name)" "Orange"
                Remove-AppxPackage -Package $_.PackageFullName -AllUsers -ErrorAction SilentlyContinue}
            Get-AppxProvisionedPackage -Online -ErrorAction SilentlyContinue|
                Where-Object{$_.DisplayName -like $app}|ForEach-Object{
                    Write-ToUI "  Removing provisioned: $($_.DisplayName)" "Orange"
                    Remove-AppxProvisionedPackage -Online -PackageName $_.PackageName -ErrorAction SilentlyContinue}
        }
    }
    if($vendorWinget.ContainsKey($vendor)-and $vendorWinget[$vendor].Count-gt 0){
        foreach($app in $vendorWinget[$vendor]){
            Write-ToUI "Uninstalling via Winget: $app"
            winget uninstall --id $app -e --accept-source-agreements -h --force 2>&1|Out-Null}
    }
    if($vendor -eq "HP"){
        $wolf=Get-CimInstance Win32_Product -ErrorAction SilentlyContinue|
              Where-Object{$_.Name -like "*HP Wolf*"-or $_.Name -like "*HP Sure Sense*"}
        foreach($item in $wolf){Write-ToUI "  Force removing: $($item.Name)" "Orange"
            Invoke-CimMethod -InputObject $item -MethodName "Uninstall"|Out-Null}
    }
    if($vendor -eq "Lenovo"){
        $vantage=Get-CimInstance Win32_Product -ErrorAction SilentlyContinue|
                 Where-Object{$_.Name -like "*Lenovo Vantage*"}
        foreach($item in $vantage){Write-ToUI "  Force removing: $($item.Name)" "Orange"
            Invoke-CimMethod -InputObject $item -MethodName "Uninstall"|Out-Null}
    }
    if($vendor -eq "Dell"){
        $ds=Get-CimInstance Win32_Product -ErrorAction SilentlyContinue|
            Where-Object{$_.Name -like "*Dell Support*"}
        foreach($item in $ds){Write-ToUI "  Force removing: $($item.Name)" "Orange"
            Invoke-CimMethod -InputObject $item -MethodName "Uninstall"|Out-Null}
    }
    Write-ToUI "$vendor bloatware removal complete!" "Lime"
    $b2.Text="  VENDOR PURGE — Auto-detect + Remove Vendor Bloat"; $b2.Enabled=$true
})

