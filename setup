$b4.Add_Click({
    [System.Media.SystemSounds]::Asterisk.Play()
    $F=New-SubForm "Account Manager" 400 340
    New-SubLbl $F "Create Local Account" 15 12 360 18 $txtMuted 8|Out-Null
    New-SubLbl $F "Username:" 15 36 360 18 $txtPrimary|Out-Null
    $tUser=New-SubTxt $F 15 56 360
    New-SubLbl $F "Full Name (optional):" 15 90 360 18 $txtPrimary|Out-Null
    $tFull=New-SubTxt $F 15 110 360
    New-SubLbl $F "Password:" 15 144 360 18 $txtPrimary|Out-Null
    $tPass=New-SubTxt $F 15 164 360; $tPass.UseSystemPasswordChar=$true
    New-SubLbl $F "Confirm Password:" 15 198 360 18 $txtPrimary|Out-Null
    $tConf=New-SubTxt $F 15 218 360; $tConf.UseSystemPasswordChar=$true
    $cbAdmin=New-Object Windows.Forms.CheckBox
    $cbAdmin.Text="Make this account a local Administrator"
    $cbAdmin.Location="15,252"; $cbAdmin.Size="360,20"
    $cbAdmin.ForeColor=$txtPrimary; $cbAdmin.BackColor=[Drawing.Color]::Transparent
    $cbAdmin.Font=New-Object Drawing.Font("Segoe UI",9); $cbAdmin.Checked=$true
    $F.Controls.Add($cbAdmin)
    $btnCreate=New-SubBtn $F "Create Account" 15 282 222 34 $btnTeal
    $btnCancel=New-SubBtn $F "Cancel" 245 282 130 34 $btnDim
    $btnCreate.Add_Click({
        $uname=$tUser.Text.Trim(); $fname=$tFull.Text.Trim()
        if([string]::IsNullOrWhiteSpace($uname)){[Windows.Forms.MessageBox]::Show("Username cannot be empty.","Error");return}
        if($tPass.Text -ne $tConf.Text){[System.Media.SystemSounds]::Hand.Play();[Windows.Forms.MessageBox]::Show("Passwords do not match!","Error");return}
        if($tPass.Text.Length -lt 1){[Windows.Forms.MessageBox]::Show("Password cannot be empty.","Error");return}
        try{$secPass=ConvertTo-SecureString $tPass.Text -AsPlainText -Force
            $params=@{Name=$uname;Password=$secPass;ErrorAction="Stop"}
            if(-not[string]::IsNullOrWhiteSpace($fname)){$params.FullName=$fname}
            New-LocalUser @params|Out-Null
            if($cbAdmin.Checked){Add-LocalGroupMember -Group "Administrators" -Member $uname -ErrorAction Stop
                Write-ToUI "Account '$uname' created as local Administrator." "Lime"}
            else{Add-LocalGroupMember -Group "Users" -Member $uname -ErrorAction Stop
                Write-ToUI "Account '$uname' created as standard User." "Lime"}
            [Windows.Forms.MessageBox]::Show("Account '$uname' created!`nGroup: $(if($cbAdmin.Checked){'Administrators'}else{'Users'})","Done")
            $F.Close()
        }catch{[Windows.Forms.MessageBox]::Show("Failed: $($_.Exception.Message)","Error")}
    })
    $btnCancel.Add_Click({$F.Close()})
    $F.ShowDialog()
})

