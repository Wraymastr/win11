$RefBtn.FlatAppearance.BorderColor=$border; $RefBtn.FlatAppearance.BorderSize=1
$InfoPanel.Controls.Add($RefBtn)

function Make-Clickable($lbl) {
    $lbl.Add_MouseEnter({ $lbl.ForeColor=$txtLinkHov; $lbl.Font=New-Object Drawing.Font("Consolas",8,[Drawing.FontStyle]::Underline) })
    $lbl.Add_MouseLeave({ $lbl.ForeColor=$txtLink;    $lbl.Font=New-Object Drawing.Font("Consolas",8) })
}
Make-Clickable $lblComputer; Make-Clickable $lblUser
Make-Clickable $lblWindows;  Make-Clickable $lblDomain
Make-Clickable $lblNetwork;  Make-Clickable $lblUptime

function Refresh-SystemInfo {
    $cs = Get-CimInstance Win32_ComputerSystem
    $os = Get-CimInstance Win32_OperatingSystem
    $lblComputer.Text = $cs.Name
    $lblUser.Text     = $env:USERNAME
    $lblWindows.Text  = "$($os.Caption) (Build $($os.BuildNumber))"
    if($cs.PartOfDomain){
        $lblDomain.Text      = "DOMAIN: $($cs.Domain)"
        $lblDomain.ForeColor = [Drawing.Color]::FromArgb(112,184,168)
    } else {
        $lblDomain.Text      = "WORKGROUP: $($cs.Workgroup)"
        $lblDomain.ForeColor = [Drawing.Color]::FromArgb(200,148,58)
    }
    $adapters = Get-NetIPAddress -AddressFamily IPv4 -ErrorAction SilentlyContinue |
                Where-Object {$_.IPAddress -notlike "127.*" -and $_.IPAddress -notlike "169.*"}
    if($adapters){
        $online    = Test-Connection -ComputerName "1.1.1.1" -Count 1 -Quiet -ErrorAction SilentlyContinue
        $onlineStr = if($online){"  [ONLINE]"}else{"  [NO INTERNET]"}
        $ipList    = ($adapters|ForEach-Object{$_.IPAddress}) -join "  /  "
        $lblNetwork.Text      = "$ipList$onlineStr"
        $lblNetwork.ForeColor = if($online){[Drawing.Color]::FromArgb(112,184,168)}else{[Drawing.Color]::FromArgb(200,112,112)}
    } else {
        $lblNetwork.Text      = "No network adapter found"
        $lblNetwork.ForeColor = [Drawing.Color]::FromArgb(200,112,112)
    }
    $up = (Get-Date) - $os.LastBootUpTime
    $lblUptime.Text = "$([int]$up.TotalHours)h $($up.Minutes)m since last boot"
}
Refresh-SystemInfo
$RefBtn.Add_Click({ Refresh-SystemInfo })

# ============================================================
# CLICK HANDLERS — INFO PANEL LABELS
# ============================================================
$lblComputer.Add_Click({
    $F = New-SubForm "Rename Computer" 380 145
    New-SubLbl $F "Current: $($lblComputer.Text)" 15 12 340 18 $txtMuted 8|Out-Null
    New-SubLbl $F "New name (max 15 characters):" 15 35 340 18 $txtPrimary|Out-Null
    $t = New-SubTxt $F 15 58 340; $t.Text=$lblComputer.Text; $t.SelectAll()
    $ok = New-SubBtn $F "Rename  (restart to apply)" 15 96 220 34 $btnBlue
    $cx = New-SubBtn $F "Cancel" 243 96 112 34 $btnDim
    $ok.Add_Click({
        $n=$t.Text.Trim()
        if([string]::IsNullOrWhiteSpace($n)-or $n-eq $lblComputer.Text){[Windows.Forms.MessageBox]::Show("Enter a new name.","No change");return}
        if($n.Length-gt 15){[Windows.Forms.MessageBox]::Show("Max 15 characters.","Too long");return}
        try{
            Rename-Computer -NewName $n -Force -ErrorAction Stop
            Write-ToUI "Renamed to '$n' — restart to apply." "Cyan"
            [Windows.Forms.MessageBox]::Show("Renamed to '$n'.`nRestart when ready.","Done")
            $F.Close(); Refresh-SystemInfo
        }catch{[Windows.Forms.MessageBox]::Show("Failed: $($_.Exception.Message)","Error")}
    })
    $cx.Add_Click({$F.Close()})
    $F.ShowDialog()
})

$lblUser.Add_Click({
    $F = New-SubForm "Change Password" 380 200
    New-SubLbl $F "Changing password for: $($env:USERNAME)" 15 12 340 18 $txtMuted 8|Out-Null
    New-SubLbl $F "New password:" 15 36 340 18 $txtPrimary|Out-Null
    $p1 = New-SubTxt $F 15 56 340; $p1.UseSystemPasswordChar=$true
    New-SubLbl $F "Confirm password:" 15 92 340 18 $txtPrimary|Out-Null
    $p2 = New-SubTxt $F 15 112 340; $p2.UseSystemPasswordChar=$true
    $ok = New-SubBtn $F "Change Password" 15 152 210 34 $btnAmb
    $cx = New-SubBtn $F "Cancel" 233 152 112 34 $btnDim
    $ok.Add_Click({
        if($p1.Text -ne $p2.Text){[System.Media.SystemSounds]::Hand.Play();[Windows.Forms.MessageBox]::Show("Passwords don't match!","Error");return}
        if($p1.Text.Length -lt 1){[Windows.Forms.MessageBox]::Show("Password can't be empty.","Error");return}
        try{
            $u=[adsi]"WinNT://./$($env:USERNAME),user"
            $u.SetPassword($p1.Text); $u.SetInfo()
            Write-ToUI "Password changed for $($env:USERNAME)." "Lime"
            [Windows.Forms.MessageBox]::Show("Password changed!","Done"); $F.Close()
        }catch{[Windows.Forms.MessageBox]::Show("Failed: $($_.Exception.Message)","Error")}
    })
    $cx.Add_Click({$F.Close()})
    $F.ShowDialog()
})

$lblWindows.Add_Click({
    $F = New-SubForm "Windows Activation" 400 145
    New-SubLbl $F "Product Key:" 15 12 360 18 $txtPrimary|Out-Null
    New-SubLbl $F "Format: XXXXX-XXXXX-XXXXX-XXXXX-XXXXX" 15 32 360 16 $txtMuted 8|Out-Null
    $t = New-SubTxt $F 15 55 360
    $t.Font=New-Object Drawing.Font("Consolas",11); $t.CharacterCasing="Upper"
    # ===========================================================
    # DEFAULT KEY — change this line when the key changes
    # ===========================================================
    $t.Text = "H3T4N-27DJJ-D2PMR-HY8BG-MKMM3"
    # ===========================================================
    $t.SelectAll()
    $ok = New-SubBtn $F "Activate Windows" 15 96 210 34 $btnTeal
    $cx = New-SubBtn $F "Cancel" 233 96 132 34 $btnDim
    $ok.Add_Click({
        $k=$t.Text.Trim()
        if($k -notmatch "^[A-Z0-9]{5}-[A-Z0-9]{5}-[A-Z0-9]{5}-[A-Z0-9]{5}-[A-Z0-9]{5}$"){
            [Windows.Forms.MessageBox]::Show("Invalid key format.","Error");return}
        try{
            Write-ToUI "Installing product key..." "Cyan"
            & cscript.exe "$env:SystemRoot\System32\slmgr.vbs" /ipk $k 2>&1|Out-Null
            Write-ToUI "Activating with Microsoft..." "Cyan"
            & cscript.exe "$env:SystemRoot\System32\slmgr.vbs" /ato 2>&1|Out-Null
            Write-ToUI "Activation complete." "Lime"
            [Windows.Forms.MessageBox]::Show("Key applied. Check Settings > Activation for status.","Done")
            $F.Close()
        }catch{[Windows.Forms.MessageBox]::Show("Failed: $($_.Exception.Message)","Error")}
    })
    $cx.Add_Click({$F.Close()})
    $F.ShowDialog()
})

$lblDomain.Add_Click({ Show-DomainTools })
$lblNetwork.Add_Click({ Show-NetworkManager })

$lblUptime.Add_Click({
    $F = New-SubForm "Power Options" 310 132
    New-SubLbl $F "What would you like to do?" 15 14 270 20 $txtPrimary 10|Out-Null
    $rb = New-SubBtn $F "Restart Now"    15 46 265 36 $btnAmb
    $sb = New-SubBtn $F "Shut Down Now"  15 90 265 36 $btnRed
    $rb.Add_Click({if([Windows.Forms.MessageBox]::Show("Restart now?","Confirm","YesNo") -eq "Yes"){Restart-Computer -Force}})
    $sb.Add_Click({if([Windows.Forms.MessageBox]::Show("Shut down now?","Confirm","YesNo") -eq "Yes"){Stop-Computer -Force}})
    $F.ShowDialog()
})

# ============================================================
# NETWORK MANAGER — called from label and button
# ============================================================
function Show-NetworkManager {
    $F = New-SubForm "Network Manager" 480 60
    $adapters = Get-NetIPAddress -AddressFamily IPv4 -ErrorAction SilentlyContinue |
                Where-Object {$_.IPAddress -notlike "127.*" -and $_.IPAddress -notlike "169.*"}
    $online = Test-Connection -ComputerName "1.1.1.1" -Count 1 -Quiet -ErrorAction SilentlyContinue

    $banner = New-Object Windows.Forms.Panel
    $banner.Location="0,0"; $banner.Size="480,36"; $banner.BorderStyle="None"
    $banner.BackColor = if($online){[Drawing.Color]::FromArgb(30,42,38)}else{[Drawing.Color]::FromArgb(42,28,28)}
    $F.Controls.Add($banner)

    $bannerLbl = New-Object Windows.Forms.Label
    $bannerLbl.Text = if($online){"  INTERNET CONNECTED"}else{"  NO INTERNET ACCESS"}
    $bannerLbl.Location="0,0"; $bannerLbl.Size="480,36"
    $bannerLbl.ForeColor = if($online){[Drawing.Color]::FromArgb(112,184,168)}else{[Drawing.Color]::FromArgb(200,112,112)}
    $bannerLbl.Font=New-Object Drawing.Font("Segoe UI",10,[Drawing.FontStyle]::Bold)
    $bannerLbl.TextAlign="MiddleLeft"; $bannerLbl.BackColor=[Drawing.Color]::Transparent
    $banner.Controls.Add($bannerLbl)

    $script:ry = 52

    if(-not $adapters){
        $noNet = New-Object Windows.Forms.Label
        $noNet.Text="No network adapters found"; $noNet.Location="16,52"; $noNet.Size="440,20"
        $noNet.ForeColor=[Drawing.Color]::FromArgb(200,112,112); $noNet.Font=New-Object Drawing.Font("Segoe UI",9)
        $F.Controls.Add($noNet); $script:ry=82
    } else {
        $adLbl = New-Object Windows.Forms.Label
        $adLbl.Text="Adapter:"; $adLbl.Location="16,52"; $adLbl.Size="80,20"
        $adLbl.ForeColor=[Drawing.Color]::FromArgb(80,80,100); $adLbl.Font=New-Object Drawing.Font("Consolas",8)
        $F.Controls.Add($adLbl)

        $adCombo = New-Object Windows.Forms.ComboBox
        $adCombo.Location="100,50"; $adCombo.Size="360,24"; $adCombo.DropDownStyle="DropDownList"
        $adCombo.BackColor=$bgInput; $adCombo.ForeColor=$txtPrimary; $adCombo.Font=New-Object Drawing.Font("Consolas",9)
        foreach($a in $adapters){$adCombo.Items.Add("$($a.InterfaceAlias)  —  $($a.IPAddress)")|Out-Null}
        $adCombo.SelectedIndex=0; $F.Controls.Add($adCombo)

        $script:ry = 90
        function Net-EditRow($key,$val){
            $kl=New-Object Windows.Forms.Label
            $kl.Text=$key; $kl.Location="16,$($script:ry)"; $kl.Size="80,20"
            $kl.ForeColor=[Drawing.Color]::FromArgb(80,80,100); $kl.Font=New-Object Drawing.Font("Consolas",8)
            $F.Controls.Add($kl)
            $tb=New-Object Windows.Forms.TextBox
            $tb.Location="100,$($script:ry)"; $tb.Size="360,24"
            $tb.BackColor=$bgInput; $tb.ForeColor=$txtPrimary; $tb.Font=New-Object Drawing.Font("Consolas",9)
            $tb.Text=$val; $F.Controls.Add($tb); $script:ry+=32; return $tb
        }

        $curAdapter=$adapters[0]; $curIface=$curAdapter.InterfaceAlias
        $gw  = (Get-NetRoute -InterfaceAlias $curIface -DestinationPrefix "0.0.0.0/0" -ErrorAction SilentlyContinue|Select-Object -First 1).NextHop
        $dns = (Get-DnsClientServerAddress -InterfaceAlias $curIface -AddressFamily IPv4 -ErrorAction SilentlyContinue).ServerAddresses -join ", "

        $txtIP     = Net-EditRow "IP Address :" $curAdapter.IPAddress
        $txtPrefix = Net-EditRow "Subnet (/):"  $curAdapter.PrefixLength
        $txtGW     = Net-EditRow "Gateway   :"  $(if($gw){$gw}else{"n/a"})
        $txtDNS    = Net-EditRow "DNS       :"  $(if($dns){$dns}else{"n/a"})

        $adCombo.Add_SelectedIndexChanged({
            $sel=$adapters[$adCombo.SelectedIndex]; $si=$sel.InterfaceAlias
            $txtIP.Text=$sel.IPAddress; $txtPrefix.Text=$sel.PrefixLength
            $gw2  = (Get-NetRoute -InterfaceAlias $si -DestinationPrefix "0.0.0.0/0" -ErrorAction SilentlyContinue|Select-Object -First 1).NextHop
            $dns2 = (Get-DnsClientServerAddress -InterfaceAlias $si -AddressFamily IPv4 -ErrorAction SilentlyContinue).ServerAddresses -join ", "
            $txtGW.Text=if($gw2){$gw2}else{"n/a"}; $txtDNS.Text=if($dns2){$dns2}else{"n/a"}
        })

        $script:ry += 10

        $btnApply = New-Object Windows.Forms.Button
        $btnApply.Text="Apply Static IP + DNS"; $btnApply.Location="16,$($script:ry)"; $btnApply.Size="190,34"
        $btnApply.FlatStyle="Flat"; $btnApply.ForeColor=$btnTeal[1]; $btnApply.BackColor=$btnTeal[0]
        $btnApply.Font=New-Object Drawing.Font("Segoe UI",9,[Drawing.FontStyle]::Bold)
        $btnApply.FlatAppearance.BorderColor=$border; $btnApply.FlatAppearance.BorderSize=1
        $btnApply.Add_Click({
            $sel=$adapters[$adCombo.SelectedIndex]; $si=$sel.InterfaceAlias
            $newIP=$txtIP.Text.Trim(); $newPfx=$txtPrefix.Text.Trim()
            $newGW=$txtGW.Text.Trim()
            $newDNS=$txtDNS.Text.Trim() -split "[,\s]+" | Where-Object{$_}
            if([string]::IsNullOrWhiteSpace($newIP)-or[string]::IsNullOrWhiteSpace($newPfx)){
                [Windows.Forms.MessageBox]::Show("IP and Subnet cannot be empty.","Error"); return}
            if([Windows.Forms.MessageBox]::Show("Apply static IP to $si ?`n`nIP: $newIP/$newPfx`nGW: $newGW`nDNS: $($newDNS -join ', ')","Confirm Static IP","YesNo") -ne "Yes"){return}
            try{
                Write-ToUI "Setting static IP on $si..." "Cyan"
                Remove-NetIPAddress -InterfaceAlias $si -Confirm:$false -ErrorAction SilentlyContinue
                Remove-NetRoute -InterfaceAlias $si -Confirm:$false -ErrorAction SilentlyContinue
                New-NetIPAddress -InterfaceAlias $si -IPAddress $newIP -PrefixLength $newPfx `
                    -DefaultGateway $(if($newGW -ne "n/a"){$newGW}else{$null}) -ErrorAction Stop|Out-Null
                if($newDNS.Count -gt 0){Set-DnsClientServerAddress -InterfaceAlias $si -ServerAddresses $newDNS -ErrorAction Stop}
                Write-ToUI "Static IP applied: $newIP/$newPfx" "Lime"
                [Windows.Forms.MessageBox]::Show("Static IP applied!","Done"); $F.Close(); Refresh-SystemInfo
            }catch{
                Write-ToUI "Static IP failed: $($_.Exception.Message)" "Orange"
                [Windows.Forms.MessageBox]::Show("Failed: $($_.Exception.Message)","Error")}
        })
        $F.Controls.Add($btnApply)

        $btnDHCP = New-Object Windows.Forms.Button
        $btnDHCP.Text="Switch to DHCP"; $btnDHCP.Location="214,$($script:ry)"; $btnDHCP.Size="140,34"
        $btnDHCP.FlatStyle="Flat"; $btnDHCP.ForeColor=$btnAmb[1]; $btnDHCP.BackColor=$btnAmb[0]
        $btnDHCP.Font=New-Object Drawing.Font("Segoe UI",9,[Drawing.FontStyle]::Bold)
        $btnDHCP.FlatAppearance.BorderColor=$border; $btnDHCP.FlatAppearance.BorderSize=1
        $btnDHCP.Add_Click({
            $sel=$adapters[$adCombo.SelectedIndex]; $si=$sel.InterfaceAlias
            if([Windows.Forms.MessageBox]::Show("Switch $si to DHCP?","Confirm DHCP","YesNo") -ne "Yes"){return}
            try{
                Write-ToUI "Switching $si to DHCP..." "Cyan"
                Set-NetIPInterface -InterfaceAlias $si -Dhcp Enabled -ErrorAction Stop
                Set-DnsClientServerAddress -InterfaceAlias $si -ResetServerAddresses -ErrorAction Stop
                Write-ToUI "$si now using DHCP." "Lime"
                [Windows.Forms.MessageBox]::Show("Switched to DHCP!","Done"); $F.Close(); Refresh-SystemInfo
            }catch{
                Write-ToUI "DHCP switch failed: $($_.Exception.Message)" "Orange"
                [Windows.Forms.MessageBox]::Show("Failed: $($_.Exception.Message)","Error")}
        })
        $F.Controls.Add($btnDHCP)
        $script:ry += 42
    }

    $btnSettings = New-Object Windows.Forms.Button
    $btnSettings.Text="Open Network Connections"; $btnSettings.Location="16,$($script:ry)"; $btnSettings.Size="210,32"
    $btnSettings.FlatStyle="Flat"; $btnSettings.ForeColor=$btnBlue[1]; $btnSettings.BackColor=$btnBlue[0]
    $btnSettings.Font=New-Object Drawing.Font("Segoe UI",9,[Drawing.FontStyle]::Bold)
    $btnSettings.FlatAppearance.BorderColor=$border; $btnSettings.FlatAppearance.BorderSize=1
    $btnSettings.Add_Click({Start-Process "ncpa.cpl"; $F.Close()})
    $F.Controls.Add($btnSettings)

    $F.Size = "480,$($script:ry+80)"
    $F.ShowDialog()
}

# ============================================================
# DOMAIN TOOLS — called from label and button
# ============================================================
function Show-DomainTools {
    $F = New-SubForm "Domain Tools" 500 480
    $cs = Get-CimInstance Win32_ComputerSystem

    $banner = New-Object Windows.Forms.Panel
    $banner.Location="0,0"; $banner.Size="500,36"; $banner.BorderStyle="None"
    $banner.BackColor = if($cs.PartOfDomain){[Drawing.Color]::FromArgb(30,42,38)}else{[Drawing.Color]::FromArgb(42,35,24)}
    $F.Controls.Add($banner)
    $bannerLbl = New-Object Windows.Forms.Label
    $bannerLbl.Text = if($cs.PartOfDomain){"  DOMAIN JOINED: $($cs.Domain)"}else{"  WORKGROUP: $($cs.Workgroup)"}
    $bannerLbl.Location="0,0"; $bannerLbl.Size="500,36"
    $bannerLbl.ForeColor = if($cs.PartOfDomain){[Drawing.Color]::FromArgb(112,184,168)}else{[Drawing.Color]::FromArgb(200,148,58)}
    $bannerLbl.Font=New-Object Drawing.Font("Segoe UI",10,[Drawing.FontStyle]::Bold)
    $bannerLbl.TextAlign="MiddleLeft"; $bannerLbl.BackColor=[Drawing.Color]::Transparent
    $banner.Controls.Add($bannerLbl)

    $fy = 46

    function DT-Section($title){
        $s=New-Object Windows.Forms.Label; $s.Text=$title
        $s.Location="15,$fy"; $s.Size="460,13"; $s.ForeColor=$txtMuted
        $s.Font=New-Object Drawing.Font("Segoe UI",7,[Drawing.FontStyle]::Bold)
        $F.Controls.Add($s); $script:fy+=$fy+18
    }

    # Join / Leave
    $s1=New-Object Windows.Forms.Label; $s1.Text="JOIN / LEAVE"
    $s1.Location="15,$fy"; $s1.Size="460,13"; $s1.ForeColor=$txtMuted
    $s1.Font=New-Object Drawing.Font("Segoe UI",7,[Drawing.FontStyle]::Bold); $F.Controls.Add($s1); $fy+=18
    New-SubLbl $F "Domain Name:" 15 $fy 460 18 $txtPrimary|Out-Null; $fy+=22
    $tDomain = New-SubTxt $F 15 $fy 460; $fy+=34
    $btnJoin  = New-SubBtn $F "Join Domain  (will reboot)" 15 $fy 220 34 $btnTeal
    $btnLeave = New-SubBtn $F "Leave Domain  (reboot)"    243 $fy 232 34 $btnRed
    $btnJoin.Add_Click({
        if([string]::IsNullOrWhiteSpace($tDomain.Text)){[Windows.Forms.MessageBox]::Show("Enter a domain name.","Error");return}
        if([Windows.Forms.MessageBox]::Show("Join '$($tDomain.Text)' and reboot?","Confirm","YesNo") -eq "Yes"){
            try{Add-Computer -DomainName $tDomain.Text -Restart -ErrorAction Stop}
            catch{[Windows.Forms.MessageBox]::Show("Failed: $($_.Exception.Message)")}}
    })
    $btnLeave.Add_Click({
        if([Windows.Forms.MessageBox]::Show("Leave domain and reboot?","Confirm","YesNo") -eq "Yes"){
            Remove-Computer -WorkgroupName "WORKGROUP" -Force -Restart}
    })
    $fy += 46

    # Group Policy
    $s2=New-Object Windows.Forms.Label; $s2.Text="GROUP POLICY"
    $s2.Location="15,$fy"; $s2.Size="460,13"; $s2.ForeColor=$txtMuted
    $s2.Font=New-Object Drawing.Font("Segoe UI",7,[Drawing.FontStyle]::Bold); $F.Controls.Add($s2); $fy+=18
    $btnGP = New-SubBtn $F "Generate GP Report  (saves to Desktop)" 15 $fy 460 34 $btnBlue
    $btnGP.Add_Click({
        Write-ToUI "Generating Group Policy report..." "Cyan"
        $gpPath="$env:USERPROFILE\Desktop\gpreport.html"
        gpresult /H $gpPath /F 2>&1|Out-Null
        if(Test-Path $gpPath){Write-ToUI "GP report saved to Desktop." "Lime"; Start-Process $gpPath}
        else{Write-ToUI "GP report failed — machine may not be domain joined." "Orange"
             [Windows.Forms.MessageBox]::Show("GP report failed.`n`nMachine may not be on a domain.","Error")}
    })
    $fy += 42
    $btnGPU = New-SubBtn $F "Force Group Policy Update  (gpupdate /force)" 15 $fy 460 34 $btnBlue
    $btnGPU.Add_Click({
        Write-ToUI "Running gpupdate /force..." "Cyan"; $F.Enabled=$false
        gpupdate /force 2>&1|Out-Null; $F.Enabled=$true
        Write-ToUI "Group Policy update complete." "Lime"
        [Windows.Forms.MessageBox]::Show("gpupdate /force complete.","Done")
    })
    $fy += 46

    # DNS
    $s3=New-Object Windows.Forms.Label; $s3.Text="DNS / REGISTRATION"
    $s3.Location="15,$fy"; $s3.Size="460,13"; $s3.ForeColor=$txtMuted
    $s3.Font=New-Object Drawing.Font("Segoe UI",7,[Drawing.FontStyle]::Bold); $F.Controls.Add($s3); $fy+=18
    $btnDNS = New-SubBtn $F "Flush DNS + Re-register in Domain" 15 $fy 460 34 $btnTeal
    $btnDNS.Add_Click({
        Write-ToUI "Flushing DNS..." "Cyan"; ipconfig /flushdns 2>&1|Out-Null
        Write-ToUI "Re-registering DNS..." "Cyan"; ipconfig /registerdns 2>&1|Out-Null
        Write-ToUI "DNS flush and re-registration complete." "Lime"
        [Windows.Forms.MessageBox]::Show("DNS flushed and re-registered.","Done")
    })
    $fy += 46

    # Azure AD
    $s4=New-Object Windows.Forms.Label; $s4.Text="AZURE AD / HYBRID JOIN"
    $s4.Location="15,$fy"; $s4.Size="460,13"; $s4.ForeColor=$txtMuted
    $s4.Font=New-Object Drawing.Font("Segoe UI",7,[Drawing.FontStyle]::Bold); $F.Controls.Add($s4); $fy+=18
    $dsregRaw    = & dsregcmd /status 2>&1
    $azureJoined = ($dsregRaw|Select-String "AzureAdJoined\s*:\s*YES") -ne $null
    $domJoined   = ($dsregRaw|Select-String "DomainJoined\s*:\s*YES")  -ne $null
    $statusText  = if($azureJoined -and $domJoined){"Hybrid Join (AD + Azure AD)"}
                   elseif($azureJoined){"Azure AD Joined only"}
                   elseif($domJoined){"On-premises AD only"}
                   else{"Not joined to any directory"}
    $statusLbl = New-Object Windows.Forms.Label
    $statusLbl.Text="Current: $statusText"; $statusLbl.Location="15,$fy"; $statusLbl.Size="460,18"
    $statusLbl.ForeColor=[Drawing.Color]::FromArgb(200,148,58); $statusLbl.Font=New-Object Drawing.Font("Segoe UI",8)
    $F.Controls.Add($statusLbl); $fy+=26
    $btnDsreg   = New-SubBtn $F "Open dsregcmd Status" 15 $fy 220 34 $btnAmb
    $btnAADLeave= New-SubBtn $F "Leave Azure AD Join"  243 $fy 232 34 $btnRed
    $btnDsreg.Add_Click({
        $output=& dsregcmd /status 2>&1|Out-String
        $tmp="$env:TEMP\dsregcmd-status.txt"; $output|Out-File $tmp -Encoding UTF8
        Start-Process "notepad.exe" $tmp
    })
    $btnAADLeave.Add_Click({
        if([Windows.Forms.MessageBox]::Show("Remove Azure AD join?`n`nMachine will need re-enrollment.`nContinue?","Confirm Azure AD Leave","YesNo") -ne "Yes"){return}
        Write-ToUI "Leaving Azure AD..." "Yellow"
        & dsregcmd /leave 2>&1|Out-Null
        Write-ToUI "Azure AD leave sent. Restart to complete." "Lime"
        [Windows.Forms.MessageBox]::Show("Azure AD leave sent.`nRestart required.","Done")
    })
    $fy += 46

    # Misc
    $s5=New-Object Windows.Forms.Label; $s5.Text="MISC"
    $s5.Location="15,$fy"; $s5.Size="460,13"; $s5.ForeColor=$txtMuted
    $s5.Font=New-Object Drawing.Font("Segoe UI",7,[Drawing.FontStyle]::Bold); $F.Controls.Add($s5); $fy+=18
    $btnRSAT = New-SubBtn $F "Open Active Directory Users & Computers" 15 $fy 460 34 $btnBlue
    $btnRSAT.Add_Click({
        try{Start-Process "dsa.msc" -ErrorAction Stop}
        catch{[Windows.Forms.MessageBox]::Show("ADUC not installed on this machine.","Not Found")}
    })
    $fy += 46

    $F.Size="500,$($fy+20)"
    $F.ShowDialog()
    Refresh-SystemInfo
}

