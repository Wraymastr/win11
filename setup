# ============================================================
function New-ActionButton($Text, $Top, $HexColor) {
    $Btn = New-Object Windows.Forms.Button
    $Btn.Text = $Text
    $Btn.Location = "10,$Top"
    $Btn.Size = "415,42"
    $Btn.FlatStyle = "Flat"
    $Btn.ForeColor = "White"
    $Btn.BackColor = [System.Drawing.ColorTranslator]::FromHtml($HexColor)
    $Btn.Font = New-Object Drawing.Font("Segoe UI", 10, [Drawing.FontStyle]::Bold)
    $Form.Controls.Add($Btn)
    return $Btn
}

