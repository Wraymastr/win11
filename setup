    $F.ShowDialog()
})

# ============================================================
# DOMAIN TOOLS — shared function (used by label click AND button)
# ============================================================
function Show-DomainTools {
    $F=New-SubForm "Domain Tools" 500 520
    $cs=Get-CimInstance Win32_ComputerSystem

    # Status banner
    $banner=New-Object Windows.Forms.Panel
    $banner.Location="0,0"; $banner.Size="500,36"; $banner.BorderStyle="None"
    $banner.BackColor=if($cs.PartOfDomain){[Drawing.Color]::FromArgb(30,42,38)}else{[Drawing.Color]::FromArgb(42,35,24)}
    $F.Controls.Add($banner)
    $bannerLbl=New-Object Windows.Forms.Label
    $bannerLbl.Text=if($cs.PartOfDomain){"  DOMAIN JOINED: $($cs.Domain)"}else{"  WORKGROUP: $($cs.Workgroup)  (not domain joined)"}
    $bannerLbl.Location="0,0"; $bannerLbl.Size="500,36"
    $bannerLbl.ForeColor=if($cs.PartOfDomain){[Drawing.Color]::FromArgb(112,184,168)}else{[Drawing.Color]::FromArgb(200,148,58)}
    $bannerLbl.Font=New-Object Drawing.Font("Segoe UI",10,[Drawing.FontStyle]::Bold)
    $bannerLbl.TextAlign="MiddleLeft"; $bannerLbl.BackColor=[Drawing.Color]::Transparent
    $banner.Controls.Add($bannerLbl)

    $fy=46

    # ---- Section: Join / Leave ----
    $s1=New-Object Windows.Forms.Label; $s1.Text="JOIN / LEAVE"
    $s1.Location="15,$fy"; $s1.Size="460,14"; $s1.ForeColor=$txtMuted
    $s1.Font=New-Object Drawing.Font("Segoe UI",7,[Drawing.FontStyle]::Bold); $F.Controls.Add($s1); $fy+=18

    New-SubLbl $F "Domain Name:" 15 $fy 460 18 $txtPrimary|Out-Null; $fy+=20
    $tDomain=New-SubTxt $F 15 $fy 460; $fy+=32

    $btnJoin=New-SubBtn $F "Join Domain  (will reboot)" 15 $fy 220 34 $btnTeal
    $btnJoin.Add_Click({
        if([string]::IsNullOrWhiteSpace($tDomain.Text)){[Windows.Forms.MessageBox]::Show("Enter a domain name.","Error");return}
        if([Windows.Forms.MessageBox]::Show("Join '$($tDomain.Text)' and reboot?","Confirm","YesNo") -eq "Yes"){
            try{Add-Computer -DomainName $tDomain.Text -Restart -ErrorAction Stop}
            catch{[Windows.Forms.MessageBox]::Show("Failed: $($_.Exception.Message)")}}
    })

    $btnLeave=New-SubBtn $F "Leave Domain  (reboot)" 243 $fy 232 34 $btnRed
    $btnLeave.Add_Click({
        if([Windows.Forms.MessageBox]::Show("Leave domain and reboot?","Confirm","YesNo") -eq "Yes"){
            Remove-Computer -WorkgroupName "WORKGROUP" -Force -Restart}
    })
    $fy+=46

    # ---- Section: GP Report ----
    $s2=New-Object Windows.Forms.Label; $s2.Text="GROUP POLICY"
    $s2.Location="15,$fy"; $s2.Size="460,14"; $s2.ForeColor=$txtMuted
    $s2.Font=New-Object Drawing.Font("Segoe UI",7,[Drawing.FontStyle]::Bold); $F.Controls.Add($s2); $fy+=18

    $btnGP=New-SubBtn $F "Generate GP Report  (saves to Desktop)" 15 $fy 460 34 $btnBlue
    $btnGP.Add_Click({
        Write-ToUI "Generating Group Policy report..." "Cyan"
        $gpPath="$env:USERPROFILE\Desktop\gpreport.html"
        try{
            gpresult /H $gpPath /F 2>&1|Out-Null
            if(Test-Path $gpPath){
                Write-ToUI "GP report saved to Desktop." "Lime"
                Start-Process $gpPath
            } else {
                Write-ToUI "GP report failed — machine may not be domain joined." "Orange"
                [Windows.Forms.MessageBox]::Show("GP report failed.`n`nThis machine may not be on a domain.","Error")
            }
        }catch{Write-ToUI "GP report error: $($_.Exception.Message)" "Orange"}
    })
    $fy+=46

    $btnGPUpdate=New-SubBtn $F "Force Group Policy Update  (gpupdate /force)" 15 $fy 460 34 $btnBlue
    $btnGPUpdate.Add_Click({
        Write-ToUI "Running gpupdate /force..." "Cyan"
        $F.Enabled=$false
        gpupdate /force 2>&1|Out-Null
        $F.Enabled=$true
        Write-ToUI "Group Policy update complete." "Lime"
        [Windows.Forms.MessageBox]::Show("gpupdate /force complete.","Done")
    })
    $fy+=46

    # ---- Section: DNS Flush / Re-register ----
    $s3=New-Object Windows.Forms.Label; $s3.Text="DNS / REGISTRATION"
    $s3.Location="15,$fy"; $s3.Size="460,14"; $s3.ForeColor=$txtMuted
    $s3.Font=New-Object Drawing.Font("Segoe UI",7,[Drawing.FontStyle]::Bold); $F.Controls.Add($s3); $fy+=18

    $btnDNS=New-SubBtn $F "Flush DNS + Re-register in Domain" 15 $fy 460 34 $btnTeal
    $btnDNS.Add_Click({
        Write-ToUI "Flushing DNS cache..." "Cyan"
        ipconfig /flushdns 2>&1|Out-Null
        Write-ToUI "Re-registering DNS..." "Cyan"
        ipconfig /registerdns 2>&1|Out-Null
        Write-ToUI "DNS flush and re-registration complete." "Lime"
        [Windows.Forms.MessageBox]::Show("DNS flushed and re-registered.","Done")
    })
    $fy+=46

    # ---- Section: Managed / Federated toggle ----
    $s4=New-Object Windows.Forms.Label; $s4.Text="AZURE AD / HYBRID JOIN"
    $s4.Location="15,$fy"; $s4.Size="460,14"; $s4.ForeColor=$txtMuted
    $s4.Font=New-Object Drawing.Font("Segoe UI",7,[Drawing.FontStyle]::Bold); $F.Controls.Add($s4); $fy+=18

    # Show current Azure AD join status
    $dsregRaw=& dsregcmd /status 2>&1
    $azureJoined  =($dsregRaw|Select-String "AzureAdJoined\s*:\s*YES") -ne $null
    $domainJoined =($dsregRaw|Select-String "DomainJoined\s*:\s*YES") -ne $null
    $hybridJoined =$azureJoined -and $domainJoined

    $statusText = if($hybridJoined){"Hybrid Join (AD + Azure AD)"}
                  elseif($azureJoined){"Azure AD Joined only"}
                  elseif($domainJoined){"On-premises AD only"}
                  else{"Not joined to any directory"}

    $statusLbl=New-Object Windows.Forms.Label
    $statusLbl.Text="Current join status: $statusText"
    $statusLbl.Location="15,$fy"; $statusLbl.Size="460,18"
    $statusLbl.ForeColor=[Drawing.Color]::FromArgb(200,148,58)
    $statusLbl.Font=New-Object Drawing.Font("Segoe UI",8)
    $F.Controls.Add($statusLbl); $fy+=26

    $btnDsreg=New-SubBtn $F "Open dsregcmd Status  (full output)" 15 $fy 220 34 $btnAmb
    $btnDsreg.Add_Click({
        $output=& dsregcmd /status 2>&1 | Out-String
        $tmpFile="$env:TEMP\dsregcmd-status.txt"
        $output|Out-File $tmpFile -Encoding UTF8
        Start-Process "notepad.exe" $tmpFile
    })

    $btnAADLeave=New-SubBtn $F "Leave Azure AD Join" 243 $fy 232 34 $btnRed
    $btnAADLeave.Add_Click({
        $confirm=[Windows.Forms.MessageBox]::Show(
            "This will remove the Azure AD join.`n`nThe machine will need to be re-enrolled or re-joined.`n`nContinue?",
            "Confirm Azure AD Leave","YesNo")
        if($confirm -ne "Yes"){return}
        try{
            Write-ToUI "Leaving Azure AD join..." "Yellow"
            & dsregcmd /leave 2>&1|Out-Null
            Write-ToUI "Azure AD leave command sent. Restart to complete." "Lime"
            [Windows.Forms.MessageBox]::Show("Azure AD leave sent.`n`nRestart required.","Done")
        }catch{[Windows.Forms.MessageBox]::Show("Failed: $($_.Exception.Message)","Error")}
    })
    $fy+=46

    # ---- Section: Misc ----
    $s5=New-Object Windows.Forms.Label; $s5.Text="MISC"
    $s5.Location="15,$fy"; $s5.Size="460,14"; $s5.ForeColor=$txtMuted
    $s5.Font=New-Object Drawing.Font("Segoe UI",7,[Drawing.FontStyle]::Bold); $F.Controls.Add($s5); $fy+=18

    $btnRSAT=New-SubBtn $F "Open Active Directory Users & Computers" 15 $fy 460 34 $btnBlue
    $btnRSAT.Add_Click({
        try{Start-Process "dsa.msc" -ErrorAction Stop}
        catch{[Windows.Forms.MessageBox]::Show("ADUC not available.`n`nRSAT tools may not be installed on this machine.","Not Found")}
    })
    $fy+=46

    $btnClose=New-SubBtn $F "Close" 15 $fy 100 30 $btnDim
    $btnClose.Add_Click({$F.Close()})

    $F.Size="500,$($fy+60)"
    $F.ShowDialog()
    Refresh-SystemInfo
}

