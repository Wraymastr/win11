function Show-AppPicker($RunAfter){
    $script:pickerSelected=$script:pickerChrome=$script:pickerVLC=$script:pickerConfirmed=$false
    $script:pickerSelected=@()

    $AF=New-Object Windows.Forms.Form
    $AF.Text="Select Apps to Install"; $AF.StartPosition="CenterParent"
    $AF.BackColor=$bgSubForm; $AF.ForeColor=$txtPrimary
    $AF.FormBorderStyle="Sizable"; $AF.MaximizeBox=$false; $AF.MinimizeBox=$false
    $AF.MinimumSize="410,500"; $AF.Size="410,680"

    $scroll=New-Object Windows.Forms.Panel
    $scroll.Location="0,0"; $scroll.Size="410,552"
    $scroll.AutoScroll=$true; $scroll.BackColor=$bgSubForm
    $scroll.Anchor="Top,Left,Right,Bottom"
    $AF.Controls.Add($scroll)

    $AF.Add_Resize({
        $scroll.Size="$($AF.ClientSize.Width),$($AF.ClientSize.Height-128)"
        $bar.Location="0,$($AF.ClientSize.Height-128)"
        $bar.Size="$($AF.ClientSize.Width),128"
        $bSA.Size="$(($AF.ClientSize.Width/2)-16),28"
        $bSN.Location="$(($AF.ClientSize.Width/2)+6),8"
        $bSN.Size="$(($AF.ClientSize.Width/2)-16),28"
        $bGo.Size="$($AF.ClientSize.Width-20),38"
        $bUpd.Size="$($AF.ClientSize.Width-20),34"
    })

    $script:ay=10; $cbs=[ordered]@{}

    function AP-Section($title){
        $s=New-Object Windows.Forms.Label
        $s.Text=$title; $s.Location="14,$($script:ay)"; $s.Size="370,14"
        $s.ForeColor=$txtMuted; $s.BackColor=[Drawing.Color]::Transparent
        $s.Font=New-Object Drawing.Font("Segoe UI",7,[Drawing.FontStyle]::Bold)
        $scroll.Controls.Add($s); $script:ay+=18
    }
    function AP-Check($label,$id,$on){
        $cb=New-Object Windows.Forms.CheckBox
        $cb.Text=$label; $cb.Location="18,$($script:ay)"; $cb.Size="360,20"
        $cb.ForeColor=$txtPrimary; $cb.BackColor=[Drawing.Color]::Transparent
        $cb.Font=New-Object Drawing.Font("Segoe UI",9); $cb.Checked=$on
        $scroll.Controls.Add($cb); $script:ay+=22; $cbs[$id]=$cb
    }

    AP-Section "CRITICAL  (ticked by default)"
    AP-Check "Microsoft 365 Desktop Suite" "Microsoft.Office"                $true
