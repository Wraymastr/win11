function Run-Debloat {
    Write-ToUI "Starting Microsoft bloat removal..." "Yellow"
    $apps = @(
        "*MicrosoftTeams*","*MSTeams*","*Clipchamp*","*Xbox*","*Cortana*",
        "*MicrosoftNews*","*BingWeather*","*GetHelp*","*FeedbackHub*",
        "*WindowsMaps*","*YourPhone*","*MicrosoftToDo*","*MicrosoftOfficeHub*",
        "*People*","*ZuneMusic*","*ZuneVideo*","Microsoft.Messaging","Microsoft.OneConnect"
    )
    foreach($app in $apps){
        Write-ToUI "Checking: $app"
        Get-AppxPackage -AllUsers -Name $app -ErrorAction SilentlyContinue|ForEach-Object{
            Write-ToUI "  Removing: $($_.Name)" "Orange"
            Remove-AppxPackage -Package $_.PackageFullName -AllUsers -ErrorAction SilentlyContinue
        }
        Get-AppxProvisionedPackage -Online -ErrorAction SilentlyContinue|
            Where-Object{$_.DisplayName -like $app}|ForEach-Object{
                Write-ToUI "  Removing provisioned: $($_.DisplayName)" "Orange"
                Remove-AppxProvisionedPackage -Online -PackageName $_.PackageName -ErrorAction SilentlyContinue
            }
    }
    Write-ToUI "Bloat removal complete!" "Lime"
}

function Run-EssentialTweaks {
    Write-ToUI "Applying essential tweaks..." "Cyan"
    Set-ItemProperty "HKLM:\SOFTWARE\Policies\Microsoft\Windows\DataCollection" "AllowTelemetry" 0 -ErrorAction SilentlyContinue
    Set-Service -Name "DiagTrack" -StartupType Disabled -ErrorAction SilentlyContinue
    $ads="HKCU:\Software\Microsoft\Windows\CurrentVersion\ContentDeliveryManager"
    "SubscribedContent-310093Enabled","SubscribedContent-353696Enabled",
    "RotatingLockScreenOverlayEnabled","SubscribedContent-338387Enabled"|ForEach-Object{
        Set-ItemProperty -Path $ads -Name $_ -Value 0 -ErrorAction SilentlyContinue}
    Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\AdvertisingInfo"          "Enabled"                  0 -ErrorAction SilentlyContinue
    Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Feeds"                    "ShellFeedsTaskbarViewMode" 2 -ErrorAction SilentlyContinue
    Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced"        "PeopleBand"               0 -ErrorAction SilentlyContinue
    Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Policies\Explorer"        "HideSCAMeetNow"           1 -ErrorAction SilentlyContinue
    Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\SearchSettings"           "IsDynamicSearchBoxPresent" 0 -ErrorAction SilentlyContinue
    Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Search"                   "BingSearchEnabled"        0 -ErrorAction SilentlyContinue
    Set-ItemProperty "HKLM:\SOFTWARE\Policies\Microsoft\Edge"                                   "StartupBoostEnabled"      0 -ErrorAction SilentlyContinue
    Set-ItemProperty "HKLM:\SOFTWARE\Microsoft\WindowsUpdate\UX\Settings"                       "ActiveHoursStart"         8 -ErrorAction SilentlyContinue
    Set-ItemProperty "HKLM:\SOFTWARE\Microsoft\WindowsUpdate\UX\Settings"                       "ActiveHoursEnd"          17 -ErrorAction SilentlyContinue
    Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced"        "HideFileExt"              0 -ErrorAction SilentlyContinue
    Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced"        "AutoCheckSelect"          0 -ErrorAction SilentlyContinue
    Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced"        "ShowTaskViewButton"        0 -ErrorAction SilentlyContinue
    Set-ItemProperty "HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\Advanced"        "TaskbarDa"                0 -ErrorAction SilentlyContinue
    powercfg.exe /hibernate off
    try{Set-TimeZone -Id "New Zealand Standard Time" -ErrorAction Stop; Write-ToUI "Timezone set to NZ." "Lime"}
    catch{Write-ToUI "Timezone change failed." "Orange"}
    Write-ToUI "Clearing startup programs..."
    @("HKCU:\Software\Microsoft\Windows\CurrentVersion\Run",
      "HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Run")|ForEach-Object{
        $p=$_
        (Get-ItemProperty -Path $p -ErrorAction SilentlyContinue).PSObject.Properties|
            Where-Object{$_.Name -notlike "PS*"}|ForEach-Object{
                Write-ToUI "  Disabling: $($_.Name)" "Orange"
                Remove-ItemProperty -Path $p -Name $_.Name -ErrorAction SilentlyContinue}}
    $wp="HKLM:\SOFTWARE\Policies\Microsoft\Dsh"
    if(-not(Test-Path $wp)){New-Item -Path $wp -Force|Out-Null}
    Set-ItemProperty $wp "AllowNewsAndInterests" 0 -ErrorAction SilentlyContinue
    $rc="HKCU:\Software\Classes\CLSID\{86ca1aa0-34aa-4e8b-a509-50c905bae2a2}\InprocServer32"
    if(-not(Test-Path $rc)){New-Item -Path $rc -Force|Out-Null}
    Set-ItemProperty $rc "(default)" "" -ErrorAction SilentlyContinue
    Stop-Process -Name "explorer" -Force -ErrorAction SilentlyContinue
    Start-Sleep -Seconds 2; Start-Process "explorer.exe"
    Write-ToUI "All essential tweaks complete!" "Lime"
}

function Run-VendorPurge {
    $manufacturer=(Get-CimInstance Win32_ComputerSystem).Manufacturer
    Write-ToUI "Detected manufacturer: $manufacturer" "Cyan"
    $vendor="Unknown"
    if($manufacturer -match "HP|Hewlett"){$vendor="HP"}
    elseif($manufacturer -match "Dell")    {$vendor="Dell"}
    elseif($manufacturer -match "Lenovo")  {$vendor="Lenovo"}
    elseif($manufacturer -match "Acer")    {$vendor="Acer"}
    elseif($manufacturer -match "ASUS")    {$vendor="ASUS"}
    elseif($manufacturer -match "MSI")     {$vendor="MSI"}
    elseif($manufacturer -match "Toshiba") {$vendor="Toshiba"}
    elseif($manufacturer -match "Samsung") {$vendor="Samsung"}
    elseif($manufacturer -match "Microsoft"){$vendor="Microsoft"}
    if($vendor -eq "Unknown"){Write-ToUI "Unknown vendor — skipping." "Orange"; return}

    Write-ToUI "Running $vendor bloatware removal..." "Yellow"
    $vendorBloat=@{
        "HP"      =@("HP.HPSupportAssistant","HP.HPQuickDrop","HP.HPPrivacySettings","HP.HPConnectionOptimizer","HP.HPSmart","HP.HPAudioCenter","HP.HPSystemEventUtility","HP.HPEnhance","HP.HPPCHardwareDiagnosticsWindows")
        "Dell"    =@("Dell.DellSupportAssistforPCs","Dell.DellOptimizer","Dell.DellDigitalDelivery","Dell.DellUpdate","Dell.DellCommandUpdate","Dell.DellPowerManager","Dell.DellCinemaGuide","Dell.DellMobileConnect","Dell.DellCinema")
        "Lenovo"  =@("E046963F.LenovoCompanion","E046963F.LenovoSettings","E0469640.LenovoUtility","LenovoCorporation.LenovoSettings","LenovoCorporation.LenovoID","LenovoCorporation.LenovoCompanion")
        "Acer"    =@("AcerIncorporated.AcerRegistration","AcerIncorporated.QuickAccess","AcerIncorporated.AcerCollection","AcerIncorporated.AcerCareCenterS","AcerIncorporated.AcerJumpStart")
        "ASUS"    =@("ASUSTeKCOMPUTERINC.MyASUS","ASUSTeKCOMPUTERINC.ASUSProductRegistrationProgram","ASUSTeKCOMPUTERINC.ASUSWelcome","ASUSTeKCOMPUTERINC.ASUSLiveUpdate")
        "MSI"     =@("MSI.CenterFacade","MSI.DragonCenter","MSI.MSICenter","MSI.MSICenterSDK")
        "Toshiba" =@("ToshibaCorporation.ToshibaServiceStation","ToshibaCorporation.SettingsforYourTOSHIBA")
        "Samsung" =@("HONHAIPREC.Samsung_Update","HONHAIPREC.SamsungUpdate")
        "Microsoft"=@("Microsoft.SurfaceHub","Microsoft.PPIProjection")
    }
    $vendorWinget=@{
        "HP"      =@("HP.HPSupportAssistant","HP.HPQuickDrop","HP.HPPrivacySettings","HP.HPConnectionOptimizer","HP.HPSmart")
        "Dell"    =@("Dell.CommandUpdate","Dell.DellOptimizer","Dell.DellSupportAssist","Dell.DellDigitalDelivery","Dell.DellPowerManager")
        "Lenovo"  =@("Lenovo.SystemUpdate","Lenovo.VantageService","Lenovo.SmartAppearance")
        "Acer"    =@("Acer.AcerCollection","Acer.QuickAccess")
        "ASUS"=@();"MSI"=@();"Toshiba"=@();"Samsung"=@();"Microsoft"=@()
    }
    foreach($app in $vendorBloat[$vendor]){
        Write-ToUI "Checking AppX: $app"
        Get-AppxPackage -AllUsers -Name $app -ErrorAction SilentlyContinue|ForEach-Object{
            Write-ToUI "  Removing: $($_.Name)" "Orange"
            Remove-AppxPackage -Package $_.PackageFullName -AllUsers -ErrorAction SilentlyContinue}
        Get-AppxProvisionedPackage -Online -ErrorAction SilentlyContinue|
            Where-Object{$_.DisplayName -like $app}|ForEach-Object{
                Write-ToUI "  Removing provisioned: $($_.DisplayName)" "Orange"
                Remove-AppxProvisionedPackage -Online -PackageName $_.PackageName -ErrorAction SilentlyContinue}
    }
    if($vendorWinget[$vendor].Count -gt 0){
        foreach($app in $vendorWinget[$vendor]){
            Write-ToUI "Uninstalling via Winget: $app"
            winget uninstall --id $app -e --accept-source-agreements -h --force 2>&1|Out-Null}
    }
    # WMI nuclear options for stubborn installs
    $wmiQueries=@{
        "HP"     =@("*HP Wolf*","*HP Sure Sense*")
        "Lenovo" =@("*Lenovo Vantage*")
        "Dell"   =@("*Dell Support*")
    }
    if($wmiQueries.ContainsKey($vendor)){
        foreach($pattern in $wmiQueries[$vendor]){
            Get-CimInstance Win32_Product -ErrorAction SilentlyContinue|
                Where-Object{$_.Name -like $pattern}|ForEach-Object{
                    Write-ToUI "  Force removing: $($_.Name)" "Orange"
                    Invoke-CimMethod -InputObject $_ -MethodName "Uninstall"|Out-Null}
        }
    }
    Write-ToUI "$vendor purge complete!" "Lime"
}

function Set-ChromeDefault {
    Write-ToUI "Setting Chrome as default browser..." "Cyan"
    $ce="${env:ProgramFiles}\Google\Chrome\Application\chrome.exe"
    if(-not(Test-Path $ce)){$ce="${env:ProgramFiles(x86)}\Google\Chrome\Application\chrome.exe"}
    if(Test-Path $ce){Start-Process $ce "--make-default-browser" -NoNewWindow -Wait; Write-ToUI "Chrome default set." "Lime"}
    else{Write-ToUI "Chrome not found — install first." "Orange"}
}

function Set-VLCDefault {
    Write-ToUI "Setting VLC as default media player..." "Cyan"
    $ve="${env:ProgramFiles}\VideoLAN\VLC\vlc.exe"
    if(-not(Test-Path $ve)){$ve="${env:ProgramFiles(x86)}\VideoLAN\VLC\vlc.exe"}
    if(-not(Test-Path $ve)){Write-ToUI "VLC not found — install first." "Orange"; return}
    ".mp4",".mkv",".avi",".mov",".wmv",".mp3",".wav",".flac",".m4a",".aac",".m4v",".ts",".mpg",".mpeg"|ForEach-Object{
        $pid2="VLC$_"; $pp="HKCU:\Software\Classes\$pid2"
        if(-not(Test-Path $pp)){New-Item -Path $pp -Force|Out-Null}
        New-Item -Path "$pp\shell\open\command" -Force|Out-Null
        Set-ItemProperty "$pp\shell\open\command" "(default)" "`"$ve`" `"%1`"" -ErrorAction SilentlyContinue
        $ep="HKCU:\Software\Classes\$_"
        if(-not(Test-Path $ep)){New-Item -Path $ep -Force|Out-Null}
        Set-ItemProperty $ep "(default)" $pid2 -ErrorAction SilentlyContinue
        $uc="HKCU:\Software\Microsoft\Windows\CurrentVersion\Explorer\FileExts\$_\UserChoice"
        if(-not(Test-Path $uc)){New-Item -Path $uc -Force|Out-Null}
        Set-ItemProperty $uc "ProgId" $pid2 -ErrorAction SilentlyContinue
    }
    Write-ToUI "VLC defaults set." "Lime"
}

function Run-Installs($AppList,$DoChrome,$DoVLC) {
    if($AppList -contains "__UPDATEALL__"){
        Write-ToUI "Running winget upgrade --all..." "Yellow"
        winget upgrade --all --silent --accept-source-agreements --accept-package-agreements
        Write-ToUI "All apps updated!" "Lime"; return
    }
    if($AppList.Count -gt 0){
        Write-ToUI "Configuring Winget..." "Cyan"
        winget settings --enable bypasscertificatepinningformicrosoftstore
        Start-Sleep -Seconds 2
        foreach($id in $AppList){
            if($id -eq "OOSU10"){
                Write-ToUI "Downloading O&O ShutUp10..." "Cyan"
                $dest="$env:TEMP\OOSU10.exe"
                try{
                    Invoke-WebRequest -Uri "https://dl5.oo-software.com/files/ooshutup10/OOSU10.exe" `
                        -OutFile $dest -UseBasicParsing -ErrorAction Stop
                    Write-ToUI "Launching ShutUp10 — configure and close it to continue." "Yellow"
                    Start-Process $dest -Wait; Write-ToUI "ShutUp10 closed." "Lime"
                }catch{Write-ToUI "ShutUp10 download failed." "Orange"}
                continue
            }
            Write-ToUI "Installing $id..."
            winget install --id $id -e --accept-source-agreements --accept-package-agreements --silent
            Write-ToUI "  Done: $id" "Lime"
        }
    }
    if($DoChrome){Set-ChromeDefault}
    if($DoVLC)   {Set-VLCDefault}
    Write-ToUI "App installs complete!" "Lime"
}

# ============================================================
# APP PICKER
# ============================================================
function Show-AppPicker($RunAfter){
    $script:pickerSelected=@(); $script:pickerChrome=$false
    $script:pickerVLC=$false;   $script:pickerConfirmed=$false

    $AF = New-Object Windows.Forms.Form
    $AF.Text="Select Apps to Install"; $AF.StartPosition="CenterParent"
    $AF.BackColor=$bgSubForm; $AF.ForeColor=$txtPrimary
    $AF.FormBorderStyle="Sizable"; $AF.MaximizeBox=$false; $AF.MinimizeBox=$false
    $AF.MinimumSize="410,500"; $AF.Size="410,680"

    $scroll = New-Object Windows.Forms.Panel
    $scroll.Location="0,0"; $scroll.Size="410,552"
    $scroll.AutoScroll=$true; $scroll.BackColor=$bgSubForm
    $scroll.Anchor="Top,Left,Right,Bottom"
    $AF.Controls.Add($scroll)

    $AF.Add_Resize({
        $scroll.Size="$($AF.ClientSize.Width),$($AF.ClientSize.Height-128)"
        $bar.Location="0,$($AF.ClientSize.Height-128)"
        $bar.Size="$($AF.ClientSize.Width),128"
        $bSA.Size="$(($AF.ClientSize.Width/2)-16),28"
        $bSN.Location="$(($AF.ClientSize.Width/2)+6),8"
        $bSN.Size="$(($AF.ClientSize.Width/2)-16),28"
        $bGo.Size="$($AF.ClientSize.Width-20),38"
        $bUpd.Size="$($AF.ClientSize.Width-20),34"
    })

    $script:ay=10; $cbs=[ordered]@{}

    function AP-Section($title){
        $s=New-Object Windows.Forms.Label; $s.Text=$title
        $s.Location="14,$($script:ay)"; $s.Size="370,14"
        $s.ForeColor=$txtMuted; $s.BackColor=[Drawing.Color]::Transparent
        $s.Font=New-Object Drawing.Font("Segoe UI",7,[Drawing.FontStyle]::Bold)
        $scroll.Controls.Add($s); $script:ay+=18
    }
    function AP-Check($label,$id,$on){
        $cb=New-Object Windows.Forms.CheckBox; $cb.Text=$label
        $cb.Location="18,$($script:ay)"; $cb.Size="360,20"
        $cb.ForeColor=$txtPrimary; $cb.BackColor=[Drawing.Color]::Transparent
        $cb.Font=New-Object Drawing.Font("Segoe UI",9); $cb.Checked=$on
        $scroll.Controls.Add($cb); $script:ay+=22; $cbs[$id]=$cb
    }

    AP-Section "CRITICAL  (ticked by default)"
    AP-Check "Microsoft 365 Desktop Suite" "Microsoft.Office"                $true
    AP-Check "Google Chrome"               "Google.Chrome"                   $true
    AP-Check "Mozilla Firefox"             "Mozilla.Firefox"                 $true
    AP-Check "Google Drive"                "Google.GoogleDrive"              $true
    AP-Check "VLC Media Player"            "VideoLAN.VLC"                    $true
    AP-Check "7-Zip"                       "7zip.7zip"                       $true
    AP-Check "Adobe Acrobat Reader"        "Adobe.Acrobat.Reader.64-bit"     $true

    $script:ay+=6
    AP-Section "OPTIONAL  (unticked by default)"
    AP-Check "LocalSend"                   "LocalSend.LocalSend"             $false
    AP-Check "CrystalDiskInfo"             "CrystalDewWorld.CrystalDiskInfo" $false
    AP-Check "Angry IP Scanner"            "Angryziber.AngryIPScanner"       $false
    AP-Check "Everything  (fast search)"   "voidtools.Everything"            $false
    AP-Check "HP Support Assistant"        "HP.HPSupportAssistant"           $false
    AP-Check "Malwarebytes"                "Malwarebytes.Malwarebytes"       $false
    AP-Check "Winaero Tweaker"             "WinAero.WinaeroTweaker"          $false
    AP-Check "O&O ShutUp10  (privacy)"     "OOSU10"                          $false
    AP-Check "PowerToys"                   "Microsoft.PowerToys"             $false
    AP-Check "Process Explorer"            "Microsoft.Sysinternals.ProcessExplorer" $false
    AP-Check "Bulk Crap Uninstaller"       "Klocman.BulkCrapUninstaller"     $false
    AP-Check "Autoruns"                    "Microsoft.Sysinternals.Autoruns" $false
    AP-Check "K-Lite Codec Pack Standard"  "CodecGuide.K-LiteCodecPack.Standard" $false

    $script:ay+=8
    AP-Section "SET AS DEFAULT"

    $cbCD=New-Object Windows.Forms.CheckBox; $cbCD.Text="Set Chrome as default browser"
    $cbCD.Location="18,$($script:ay)"; $cbCD.Size="360,20"
    $cbCD.ForeColor=$txtPrimary; $cbCD.BackColor=[Drawing.Color]::Transparent
    $cbCD.Font=New-Object Drawing.Font("Segoe UI",9); $cbCD.Checked=$true
    $scroll.Controls.Add($cbCD); $script:ay+=22

    $cbVD=New-Object Windows.Forms.CheckBox; $cbVD.Text="Set VLC as default media player"
    $cbVD.Location="18,$($script:ay)"; $cbVD.Size="360,20"
    $cbVD.ForeColor=$txtPrimary; $cbVD.BackColor=[Drawing.Color]::Transparent
    $cbVD.Font=New-Object Drawing.Font("Segoe UI",9); $cbVD.Checked=$true
    $scroll.Controls.Add($cbVD); $script:ay+=30

    $pad=New-Object Windows.Forms.Label; $pad.Size="10,20"
    $pad.Location="0,$($script:ay)"; $scroll.Controls.Add($pad)

    $bar=New-Object Windows.Forms.Panel
    $bar.Location="0,552"; $bar.Size="410,128"
    $bar.BackColor=[Drawing.Color]::FromArgb(22,22,27); $bar.Anchor="Bottom,Left,Right"
    $AF.Controls.Add($bar)

    $line=New-Object Windows.Forms.Label
    $line.Location="0,0"; $line.Size="410,1"
    $line.BackColor=[Drawing.Color]::FromArgb(42,42,53); $bar.Controls.Add($line)

    $bSA=New-Object Windows.Forms.Button; $bSA.Text="Select All"
    $bSA.Location="10,8"; $bSA.Size="178,28"; $bSA.FlatStyle="Flat"
    $bSA.ForeColor=$txtPrimary; $bSA.BackColor=$bgPanel
    $bSA.FlatAppearance.BorderColor=$border; $bSA.FlatAppearance.BorderSize=1
    $bSA.Add_Click({foreach($c in $cbs.Values){$c.Checked=$true};$cbCD.Checked=$true;$cbVD.Checked=$true})
    $bar.Controls.Add($bSA)

    $bSN=New-Object Windows.Forms.Button; $bSN.Text="Select None"
    $bSN.Location="196,8"; $bSN.Size="178,28"; $bSN.FlatStyle="Flat"
    $bSN.ForeColor=$txtPrimary; $bSN.BackColor=$bgPanel
    $bSN.FlatAppearance.BorderColor=$border; $bSN.FlatAppearance.BorderSize=1
    $bSN.Add_Click({foreach($c in $cbs.Values){$c.Checked=$false};$cbCD.Checked=$false;$cbVD.Checked=$false})
    $bar.Controls.Add($bSN)

    $bGo=New-Object Windows.Forms.Button; $bGo.Text="  INSTALL SELECTED"
    $bGo.Location="10,44"; $bGo.Size="364,38"; $bGo.FlatStyle="Flat"
    $bGo.ForeColor=$btnTeal[1]; $bGo.BackColor=$btnTeal[0]
    $bGo.Font=New-Object Drawing.Font("Segoe UI",10,[Drawing.FontStyle]::Bold)
    $bGo.FlatAppearance.BorderColor=$border; $bGo.FlatAppearance.BorderSize=1
    $bGo.TextAlign="MiddleLeft"; $bGo.Padding=New-Object Windows.Forms.Padding(10,0,0,0)
    $bGo.Add_Click({
        $sel=@(); foreach($id in $cbs.Keys){if($cbs[$id].Checked){$sel+=$id}}
        if($sel.Count -eq 0 -and -not $cbCD.Checked -and -not $cbVD.Checked){
            [Windows.Forms.MessageBox]::Show("Nothing selected!","Nothing to do"); return}
        $script:pickerSelected=$sel; $script:pickerChrome=$cbCD.Checked
        $script:pickerVLC=$cbVD.Checked; $script:pickerConfirmed=$true
        $AF.Close()
    })
    $bar.Controls.Add($bGo)

    $bUpd=New-Object Windows.Forms.Button; $bUpd.Text="  Update All Installed Applications"
    $bUpd.Location="10,86"; $bUpd.Size="364,34"; $bUpd.FlatStyle="Flat"
    $bUpd.ForeColor=[Drawing.Color]::FromArgb(200,148,58); $bUpd.BackColor=[Drawing.Color]::FromArgb(42,35,24)
    $bUpd.Font=New-Object Drawing.Font("Segoe UI",9,[Drawing.FontStyle]::Bold)
    $bUpd.FlatAppearance.BorderColor=$border; $bUpd.FlatAppearance.BorderSize=1
    $bUpd.TextAlign="MiddleLeft"; $bUpd.Padding=New-Object Windows.Forms.Padding(10,0,0,0)
    $bUpd.Add_Click({
        $script:pickerSelected=@("__UPDATEALL__"); $script:pickerChrome=$false
        $script:pickerVLC=$false; $script:pickerConfirmed=$true; $AF.Close()
    })
    $bar.Controls.Add($bUpd)

    $AF.ShowDialog()|Out-Null

    if($script:pickerConfirmed){& $RunAfter $script:pickerSelected $script:pickerChrome $script:pickerVLC}
    else{$b3.Text="  APPLICATION PROVISIONING"; $b3.Enabled=$true}
}

