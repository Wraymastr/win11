# Scroll each line in with a short delay so it feels alive
$bannerTimer = New-Object Windows.Forms.Timer
$bannerTimer.Interval = 18   # ms between lines — lower = faster scroll
$bannerIndex = 0
$bannerTimer.Add_Tick({
    if($bannerIndex -lt $bannerLines.Count) {
        $line = $bannerLines[$bannerIndex]
        # Colour the ASCII art differently from the rest
        if($bannerIndex -ge 1 -and $bannerIndex -le 6) {
            Write-ToUI $line "Cyan"
        } elseif($line -match "^  >") {
            Write-ToUI $line "Yellow"
        } elseif($line -match "^  Tip:") {
            Write-ToUI $line "Orange"
        } elseif($line -match "Waiting") {
            Write-ToUI $line "Lime"
        } else {
            Write-ToUI $line "Gray"
        }
        $script:bannerIndex++
    } else {
        $bannerTimer.Stop()
    }
})
$script:bannerIndex = 0
$bannerTimer.Start()
