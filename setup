$lblUptime.Add_Click({
    $F=New-SubForm "Power Options" 310 172
    New-SubLbl $F "What would you like to do?" 15 14 270 20 $txtPrimary 10|Out-Null
    $rb=New-SubBtn $F "Restart Now" 15 46 265 36 $btnAmb
