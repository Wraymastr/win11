    [Windows.Forms.MessageBox]::Show("Please run as Administrator!", "Error")
    break
}

# ============================================================
# THEME — dark charcoal, two accent colors only
# ============================================================
$bg          = [Drawing.Color]::FromArgb(30,  30,  36)   # main window bg
$bgPanel     = [Drawing.Color]::FromArgb(22,  22,  27)   # info panel / titlebar
$bgConsole   = [Drawing.Color]::FromArgb(15,  15,  18)   # console area
$bgSubForm   = [Drawing.Color]::FromArgb(30,  30,  36)   # sub-window bg
$bgInput     = [Drawing.Color]::FromArgb(22,  22,  27)   # textbox bg
$border      = [Drawing.Color]::FromArgb(42,  42,  53)   # panel border
$txtPrimary  = [Drawing.Color]::FromArgb(200, 200, 212)  # main text
$txtMuted    = [Drawing.Color]::FromArgb(80,  80,  100)  # labels/dividers
$txtConsole  = [Drawing.Color]::FromArgb(110, 188, 110)  # console green
$txtLink     = [Drawing.Color]::FromArgb(126, 184, 212)  # clickable labels (blue-ish)
$txtLinkHov  = [Drawing.Color]::FromArgb(180, 220, 240)  # hover

# Button bg / fg pairs  [bg, fg]
$btnRun  = @([Drawing.Color]::FromArgb(37,37,53),  [Drawing.Color]::FromArgb(155,143,212))
$btnRed  = @([Drawing.Color]::FromArgb(42,30,30),  [Drawing.Color]::FromArgb(200,112,112))
$btnAmb  = @([Drawing.Color]::FromArgb(42,35,24),  [Drawing.Color]::FromArgb(200,148,58))
$btnTeal = @([Drawing.Color]::FromArgb(30,42,42),  [Drawing.Color]::FromArgb(112,184,168))
$btnBlue = @([Drawing.Color]::FromArgb(30,37,48),  [Drawing.Color]::FromArgb(112,152,200))
$btnDim  = @([Drawing.Color]::FromArgb(22,22,27),  [Drawing.Color]::FromArgb(80,80,100))

# ============================================================
# HELPERS
# ============================================================
function New-Btn($parent, $text, $x, $y, $w, $h, $pair) {
    $b = New-Object Windows.Forms.Button
    $b.Text = $text; $b.Location = "$x,$y"; $b.Size = "$w,$h"
    $b.FlatStyle = "Flat"; $b.ForeColor = $pair[1]; $b.BackColor = $pair[0]
    $b.Font = New-Object Drawing.Font("Segoe UI", 9, [Drawing.FontStyle]::Bold)
    $b.FlatAppearance.BorderColor = $border; $b.FlatAppearance.BorderSize = 1
    $b.TextAlign = "MiddleLeft"; $b.Padding = New-Object Windows.Forms.Padding(8,0,0,0)
    $parent.Controls.Add($b); return $b
}

function New-Lbl($parent, $text, $x, $y, $w, $h, $color, $size=8, $style="Regular") {
    $l = New-Object Windows.Forms.Label
    $l.Text=$text; $l.Location="$x,$y"; $l.Size="$w,$h"
    $l.ForeColor=$color; $l.BackColor=[Drawing.Color]::Transparent
    $l.Font=New-Object Drawing.Font("Consolas",$size,[Drawing.FontStyle]::$style)
    $parent.Controls.Add($l); return $l
}

function New-SectionLbl($text, $y) {
    $l = New-Object Windows.Forms.Label
    $l.Text=$text; $l.Location="12,$y"; $l.Size="430,14"
    $l.ForeColor=$txtMuted; $l.BackColor=[Drawing.Color]::Transparent
    $l.Font=New-Object Drawing.Font("Segoe UI",7,[Drawing.FontStyle]::Bold)
    $Form.Controls.Add($l)
}

# ============================================================
# MAIN WINDOW  — 500 wide x 660 tall (more square, smaller)
# ============================================================
$Form = New-Object Windows.Forms.Form
$Form.Text = "APEX CONFIGURATOR"
$Form.Size = "500,720"
$Form.MinimumSize = "500,560"
$Form.StartPosition = "CenterScreen"
$Form.BackColor = $bg
$Form.FormBorderStyle = "Sizable"      # resizable!
$Form.MaximizeBox = $false

# ============================================================
# INFO PANEL
# ============================================================
$InfoPanel = New-Object Windows.Forms.Panel
$InfoPanel.Location = "10,8"
$InfoPanel.Size = "470,108"
$InfoPanel.BackColor = $bgPanel
$InfoPanel.BorderStyle = "FixedSingle"
$Form.Controls.Add($InfoPanel)

$rowY = @(8,24,40,56,72,88)
$keys = @("COMPUTER :","USER     :","WINDOWS  :","DOMAIN   :","NETWORK  :","UPTIME   :")
$keyLbls = @(); $valLbls = @()
for ($i=0; $i -lt 6; $i++) {
    $kl = New-Lbl $InfoPanel $keys[$i] 8 $rowY[$i] 82 16 $txtMuted 8
    $vl = New-Lbl $InfoPanel "" 92 $rowY[$i] 355 16 $txtLink 8
    $vl.Cursor = [Windows.Forms.Cursors]::Hand
    $keyLbls += $kl; $valLbls += $vl
}
$lblComputer=$valLbls[0]; $lblUser=$valLbls[1]
$lblWindows=$valLbls[2];  $lblDomain=$valLbls[3]
$lblNetwork=$valLbls[4];  $lblUptime=$valLbls[5]

$RefBtn = New-Object Windows.Forms.Button
$RefBtn.Text="Refresh"; $RefBtn.Location="390,85"; $RefBtn.Size="68,16"
$RefBtn.FlatStyle="Flat"; $RefBtn.ForeColor=$txtMuted; $RefBtn.BackColor=$bgPanel
$RefBtn.Font=New-Object Drawing.Font("Segoe UI",7)
$RefBtn.FlatAppearance.BorderColor=$border; $RefBtn.FlatAppearance.BorderSize=1
$InfoPanel.Controls.Add($RefBtn)

function Make-Clickable($lbl) {
    $lbl.Add_MouseEnter({ $lbl.ForeColor=$txtLinkHov; $lbl.Font=New-Object Drawing.Font("Consolas",8,[Drawing.FontStyle]::Underline) })
    $lbl.Add_MouseLeave({ $lbl.ForeColor=$txtLink;    $lbl.Font=New-Object Drawing.Font("Consolas",8) })
}
Make-Clickable $lblComputer; Make-Clickable $lblUser
Make-Clickable $lblWindows;  Make-Clickable $lblDomain
Make-Clickable $lblNetwork;  Make-Clickable $lblUptime

function Refresh-SystemInfo {
    $cs = Get-CimInstance Win32_ComputerSystem
    $os = Get-CimInstance Win32_OperatingSystem

    $lblComputer.Text = $cs.Name
    $lblUser.Text     = $env:USERNAME
    $lblWindows.Text  = "$($os.Caption) (Build $($os.BuildNumber))"

    if ($cs.PartOfDomain) {
        $lblDomain.Text     = "DOMAIN: $($cs.Domain)"
        $lblDomain.ForeColor= [Drawing.Color]::FromArgb(112,184,168)
    } else {
        $lblDomain.Text     = "WORKGROUP: $($cs.Workgroup)"
        $lblDomain.ForeColor= [Drawing.Color]::FromArgb(200,148,58)
    }

    # Network info — grab first non-loopback IPv4
    # Inside Refresh-SystemInfo — replace the network section:
    $adapters = Get-NetIPAddress -AddressFamily IPv4 -ErrorAction SilentlyContinue |
                Where-Object { $_.IPAddress -notlike "127.*" -and $_.IPAddress -notlike "169.*" }

    if ($adapters) {
        $online = Test-Connection -ComputerName "1.1.1.1" -Count 1 -Quiet -ErrorAction SilentlyContinue
        $onlineStr = if ($online) { "  [ONLINE]" } else { "  [NO INTERNET]" }
        # Show all adapter IPs joined together
        $ipList = ($adapters | ForEach-Object { $_.IPAddress }) -join "  /  "
        $lblNetwork.Text      = "$ipList$onlineStr"
        $lblNetwork.ForeColor = if ($online) { [Drawing.Color]::FromArgb(112,184,168) } else { [Drawing.Color]::FromArgb(200,112,112) }
    } else {
        $lblNetwork.Text      = "No network adapter found"
        $lblNetwork.ForeColor = [Drawing.Color]::FromArgb(200,112,112)
    }

    $up = (Get-Date) - $os.LastBootUpTime
    $lblUptime.Text = "$([int]$up.TotalHours)h $($up.Minutes)m since last boot"
}
Refresh-SystemInfo
$RefBtn.Add_Click({ Refresh-SystemInfo })

# ============================================================
# SUB-WINDOW FACTORY — dark themed, always closes BEFORE work
# ============================================================
function New-SubForm($title, $w, $h) {
    $f = New-Object Windows.Forms.Form
    $f.Text=$title; $f.Size="$w,$h"; $f.StartPosition="CenterParent"
    $f.BackColor=$bgSubForm; $f.ForeColor=$txtPrimary
    $f.FormBorderStyle="FixedDialog"; $f.MaximizeBox=$false; $f.MinimizeBox=$false
    return $f
}

function New-SubBtn($parent,$text,$x,$y,$w,$h,$pair) {
    $b=New-Object Windows.Forms.Button
    $b.Text=$text; $b.Location="$x,$y"; $b.Size="$w,$h"
    $b.FlatStyle="Flat"; $b.ForeColor=$pair[1]; $b.BackColor=$pair[0]
    $b.Font=New-Object Drawing.Font("Segoe UI",9,[Drawing.FontStyle]::Bold)
    $b.FlatAppearance.BorderColor=$border; $b.FlatAppearance.BorderSize=1
    $parent.Controls.Add($b); return $b
}

function New-SubLbl($parent,$text,$x,$y,$w,$h,$color,$size=9) {
    $l=New-Object Windows.Forms.Label
    $l.Text=$text; $l.Location="$x,$y"; $l.Size="$w,$h"
    $l.ForeColor=$color; $l.BackColor=[Drawing.Color]::Transparent
    $l.Font=New-Object Drawing.Font("Segoe UI",$size)
    $parent.Controls.Add($l); return $l
}

function New-SubTxt($parent,$x,$y,$w,$val="") {
    $t=New-Object Windows.Forms.TextBox
    $t.Location="$x,$y"; $t.Size="$w,24"
    $t.BackColor=$bgInput; $t.ForeColor=$txtPrimary
    $t.BorderStyle="FixedSingle"; $t.Font=New-Object Drawing.Font("Segoe UI",9)
    $t.Text=$val
    $parent.Controls.Add($t); return $t
}

# ============================================================
# CLICK: COMPUTER -> RENAME
# ============================================================
$lblComputer.Add_Click({
    $F=New-SubForm "Rename Computer" 380 185
    New-SubLbl $F "Current: $($lblComputer.Text)" 15 12 340 18 $txtMuted 8 | Out-Null
    New-SubLbl $F "New name (max 15 characters):" 15 35 340 18 $txtPrimary | Out-Null
    $t=New-SubTxt $F 15 58 340
    $t.Text=$lblComputer.Text; $t.SelectAll()
    $ok=New-SubBtn $F "Rename  (restart to apply)" 15 96 220 34 $btnBlue
    $cx=New-SubBtn $F "Cancel" 243 96 112 34 $btnDim
    $ok.Add_Click({
        $n=$t.Text.Trim()
        if([string]::IsNullOrWhiteSpace($n)-or $n-eq $lblComputer.Text){[Windows.Forms.MessageBox]::Show("Enter a new name.","No change");return}
        if($n.Length-gt 15){[Windows.Forms.MessageBox]::Show("Max 15 characters.","Too long");return}
        try{Rename-Computer -NewName $n -Force -ErrorAction Stop
            Write-ToUI "Renamed to '$n' — restart to apply." "Cyan"
            [Windows.Forms.MessageBox]::Show("Renamed to '$n'.`nRestart when ready.","Done")
            $F.Close(); Refresh-SystemInfo
        }catch{[Windows.Forms.MessageBox]::Show("Failed: $($_.Exception.Message)","Error")}
    })
    $cx.Add_Click({$F.Close()})
    $F.ShowDialog()
})

# ============================================================
# CLICK: USER -> PASSWORD CHANGE
# ============================================================
$lblUser.Add_Click({
    $F=New-SubForm "Change Password" 380 240
    New-SubLbl $F "Changing password for: $($env:USERNAME)" 15 12 340 18 $txtMuted 8 | Out-Null
    New-SubLbl $F "New password:" 15 36 340 18 $txtPrimary | Out-Null
    $p1=New-SubTxt $F 15 56 340; $p1.UseSystemPasswordChar=$true
    New-SubLbl $F "Confirm password:" 15 92 340 18 $txtPrimary | Out-Null
    $p2=New-SubTxt $F 15 112 340; $p2.UseSystemPasswordChar=$true
    $ok=New-SubBtn $F "Change Password" 15 152 210 34 $btnAmb
    $cx=New-SubBtn $F "Cancel" 233 152 112 34 $btnDim
    $ok.Add_Click({
        if($p1.Text-ne $p2.Text){[System.Media.SystemSounds]::Hand.Play();[Windows.Forms.MessageBox]::Show("Passwords don't match!","Error");return}
        if($p1.Text.Length-lt 1){[Windows.Forms.MessageBox]::Show("Password can't be empty.","Error");return}
        try{$u=[adsi]"WinNT://./$($env:USERNAME),user";$u.SetPassword($p1.Text);$u.SetInfo()
            Write-ToUI "Password changed for $($env:USERNAME)." "Lime"
            [Windows.Forms.MessageBox]::Show("Password changed!","Done"); $F.Close()
        }catch{[Windows.Forms.MessageBox]::Show("Failed: $($_.Exception.Message)","Error")}
    })
    $cx.Add_Click({$F.Close()})
    $F.ShowDialog()
})

# ============================================================
# CLICK: WINDOWS -> PRODUCT KEY
# ============================================================
$lblWindows.Add_Click({
    $F=New-SubForm "Windows Activation" 400 185
    New-SubLbl $F "Product Key:" 15 12 360 18 $txtPrimary | Out-Null
    New-SubLbl $F "Format: XXXXX-XXXXX-XXXXX-XXXXX-XXXXX" 15 32 360 16 $txtMuted 8 | Out-Null
    $t=New-SubTxt $F 15 55 360
    $t.Font=New-Object Drawing.Font("Consolas",11); $t.CharacterCasing="Upper"
    # ===========================================================
    # DEFAULT KEY — change this line when the key changes
    # ===========================================================
    $t.Text="H3T4N-27DJJ-D2PMR-HY8BG-MKMM3"
    # ===========================================================
    $t.SelectAll()
    $ok=New-SubBtn $F "Activate Windows" 15 96 210 34 $btnTeal
    $cx=New-SubBtn $F "Cancel" 233 96 132 34 $btnDim
    $ok.Add_Click({
        $k=$t.Text.Trim()
        if($k -notmatch "^[A-Z0-9]{5}-[A-Z0-9]{5}-[A-Z0-9]{5}-[A-Z0-9]{5}-[A-Z0-9]{5}$"){
            [Windows.Forms.MessageBox]::Show("Invalid key format.","Error");return}
        try{Write-ToUI "Installing product key..." "Cyan"
            & cscript.exe "$env:SystemRoot\System32\slmgr.vbs" /ipk $k 2>&1 | Out-Null
            Write-ToUI "Activating with Microsoft..." "Cyan"
            & cscript.exe "$env:SystemRoot\System32\slmgr.vbs" /ato 2>&1 | Out-Null
            Write-ToUI "Activation complete." "Lime"
            [Windows.Forms.MessageBox]::Show("Key applied. Check Settings > Activation for status.","Done")
            $F.Close()
        }catch{[Windows.Forms.MessageBox]::Show("Failed: $($_.Exception.Message)","Error")}
    })
    $cx.Add_Click({$F.Close()})
    $F.ShowDialog()
})

# ============================================================
# CLICK: DOMAIN -> DOMAIN TOOLS
# ============================================================
$lblDomain.Add_Click({
    $F=New-SubForm "Domain Manager" 380 230
    New-SubLbl $F "Domain Name:" 15 15 340 18 $txtPrimary | Out-Null
    $t=New-SubTxt $F 15 38 340
    $jb=New-SubBtn $F "Join Domain  (will reboot)" 15 78 340 36 $btnTeal
    $lb=New-SubBtn $F "Leave Domain  (return to WORKGROUP)" 15 122 340 36 $btnRed
    $jb.Add_Click({
        if([string]::IsNullOrWhiteSpace($t.Text)){[System.Media.SystemSounds]::Hand.Play();[Windows.Forms.MessageBox]::Show("Enter a domain name.","Error");return}
        if([Windows.Forms.MessageBox]::Show("Join '$($t.Text)' and reboot?","Confirm","YesNo") -eq "Yes"){
            try{Add-Computer -DomainName $t.Text -Restart -ErrorAction Stop}
            catch{[Windows.Forms.MessageBox]::Show("Failed: $($_.Exception.Message)")}}
    })
    $lb.Add_Click({
        if([Windows.Forms.MessageBox]::Show("Leave domain and reboot?","Confirm","YesNo") -eq "Yes"){
            Remove-Computer -WorkgroupName "WORKGROUP" -Force -Restart}
    })
    $F.Controls.AddRange(@()) # already added via New-SubBtn
    $F.ShowDialog(); Refresh-SystemInfo
})
# ============================================================
# CLICK: NETWORK -> REFRESH SYSTEM INFO
# ============================================================
$lblNetwork.Add_Click({
    $F = New-SubForm "Network Details" 480 100

    $adapters = Get-NetIPAddress -AddressFamily IPv4 -ErrorAction SilentlyContinue |
                Where-Object { $_.IPAddress -notlike "127.*" -and $_.IPAddress -notlike "169.*" }
    $online = Test-Connection -ComputerName "1.1.1.1" -Count 1 -Quiet -ErrorAction SilentlyContinue

    # Status banner
    $banner = New-Object Windows.Forms.Panel
    $banner.Location="0,0"; $banner.Size="480,36"; $banner.BorderStyle="None"
    $banner.BackColor = if($online){[Drawing.Color]::FromArgb(30,42,38)}else{[Drawing.Color]::FromArgb(42,28,28)}
    $F.Controls.Add($banner)

    $bannerLbl = New-Object Windows.Forms.Label
    $bannerLbl.Text = if($online){"  INTERNET CONNECTED"}else{"  NO INTERNET ACCESS"}
    $bannerLbl.Location="0,0"; $bannerLbl.Size="480,36"
    $bannerLbl.ForeColor = if($online){[Drawing.Color]::FromArgb(112,184,168)}else{[Drawing.Color]::FromArgb(200,112,112)}
    $bannerLbl.Font=New-Object Drawing.Font("Segoe UI",10,[Drawing.FontStyle]::Bold)
    $bannerLbl.TextAlign="MiddleLeft"; $bannerLbl.BackColor=[Drawing.Color]::Transparent
    $banner.Controls.Add($bannerLbl)

    $script:ry = 52

    # If no adapters, just show the "open settings" button
    if(-not $adapters) {
        $noNet = New-Object Windows.Forms.Label
        $noNet.Text="No network adapters found"; $noNet.Location="16,52"; $noNet.Size="440,20"
        $noNet.ForeColor=[Drawing.Color]::FromArgb(200,112,112)
        $noNet.Font=New-Object Drawing.Font("Segoe UI",9)
        $F.Controls.Add($noNet)
        $script:ry = 82
    } else {
        # Adapter selector dropdown
        $adLbl = New-Object Windows.Forms.Label
        $adLbl.Text="Adapter:"; $adLbl.Location="16,52"; $adLbl.Size="80,20"
        $adLbl.ForeColor=[Drawing.Color]::FromArgb(80,80,100)
        $adLbl.Font=New-Object Drawing.Font("Consolas",8)
        $F.Controls.Add($adLbl)

        $adCombo = New-Object Windows.Forms.ComboBox
        $adCombo.Location="100,50"; $adCombo.Size="360,24"
        $adCombo.DropDownStyle="DropDownList"
        $adCombo.BackColor=$bgInput; $adCombo.ForeColor=$txtPrimary
        $adCombo.Font=New-Object Drawing.Font("Consolas",9)
        foreach($a in $adapters){ $adCombo.Items.Add("$($a.InterfaceAlias)  —  $($a.IPAddress)") | Out-Null }
        $adCombo.SelectedIndex=0
        $F.Controls.Add($adCombo)

        # Editable fields
        $script:ry = 90

        function Net-EditRow($key, $val, $readOnly=$false) {
            $kl=New-Object Windows.Forms.Label
            $kl.Text=$key; $kl.Location="16,$($script:ry)"; $kl.Size="80,20"
            $kl.ForeColor=[Drawing.Color]::FromArgb(80,80,100)
            $kl.Font=New-Object Drawing.Font("Consolas",8)
            $F.Controls.Add($kl)

            $tb=New-Object Windows.Forms.TextBox
            $tb.Location="100,$($script:ry)"; $tb.Size="360,24"
            $tb.BackColor=$bgInput; $tb.ForeColor=$txtPrimary
            $tb.Font=New-Object Drawing.Font("Consolas",9)
            $tb.Text=$val; $tb.ReadOnly=$readOnly
            $F.Controls.Add($tb)

            $script:ry += 32
            return $tb
        }

        # Get current adapter details
        $curAdapter = $adapters[0]
        $curIface   = $curAdapter.InterfaceAlias
        $curIP      = $curAdapter.IPAddress
        $curPrefix  = $curAdapter.PrefixLength

        $gw  = (Get-NetRoute -InterfaceAlias $curIface -DestinationPrefix "0.0.0.0/0" -ErrorAction SilentlyContinue |
                Select-Object -First 1).NextHop
        $dns = (Get-DnsClientServerAddress -InterfaceAlias $curIface -AddressFamily IPv4 -ErrorAction SilentlyContinue).ServerAddresses -join ", "

        # Create the editable fields
        $txtIP      = Net-EditRow "IP Address :" $curIP
        $txtPrefix  = Net-EditRow "Subnet (/):" $curPrefix
        $txtGW      = Net-EditRow "Gateway   :" $(if($gw){$gw}else{"n/a"})
        $txtDNS     = Net-EditRow "DNS       :" $(if($dns){$dns}else{"n/a"})

        # When adapter selection changes, reload the fields
        $adCombo.Add_SelectedIndexChanged({
            $selAdapter = $adapters[$adCombo.SelectedIndex]
            $selIface   = $selAdapter.InterfaceAlias
            $txtIP.Text     = $selAdapter.IPAddress
            $txtPrefix.Text = $selAdapter.PrefixLength
            $gw2  = (Get-NetRoute -InterfaceAlias $selIface -DestinationPrefix "0.0.0.0/0" -ErrorAction SilentlyContinue |
                     Select-Object -First 1).NextHop
            $dns2 = (Get-DnsClientServerAddress -InterfaceAlias $selIface -AddressFamily IPv4 -ErrorAction SilentlyContinue).ServerAddresses -join ", "
            $txtGW.Text  = if($gw2){$gw2}else{"n/a"}
            $txtDNS.Text = if($dns2){$dns2}else{"n/a"}
        })

        $script:ry += 10

        # Apply Static IP button
        $btnApply = New-Object Windows.Forms.Button
        $btnApply.Text="Apply Static IP + DNS"
        $btnApply.Location="16,$($script:ry)"; $btnApply.Size="190,34"
        $btnApply.FlatStyle="Flat"; $btnApply.ForeColor=$btnTeal[1]; $btnApply.BackColor=$btnTeal[0]
        $btnApply.Font=New-Object Drawing.Font("Segoe UI",9,[Drawing.FontStyle]::Bold)
        $btnApply.FlatAppearance.BorderColor=$border; $btnApply.FlatAppearance.BorderSize=1
        $btnApply.Add_Click({
            $selAdapter = $adapters[$adCombo.SelectedIndex]
            $selIface   = $selAdapter.InterfaceAlias
            $selIfIndex = $selAdapter.InterfaceIndex

            $newIP     = $txtIP.Text.Trim()
            $newPrefix = $txtPrefix.Text.Trim()
            $newGW     = $txtGW.Text.Trim()
            $newDNS    = $txtDNS.Text.Trim() -split "[,\s]+" | Where-Object {$_}

            if([string]::IsNullOrWhiteSpace($newIP) -or [string]::IsNullOrWhiteSpace($newPrefix)){
                [Windows.Forms.MessageBox]::Show("IP and Subnet cannot be empty.","Error"); return}

            $confirm = [Windows.Forms.MessageBox]::Show(
                "Apply static IP to $selIface ?`n`nIP: $newIP/$newPrefix`nGW: $newGW`nDNS: $($newDNS -join ', ')",
                "Confirm Static IP","YesNo")
            if($confirm -ne "Yes"){return}

            try {
                Write-ToUI "Setting static IP on $selIface..." "Cyan"
                # Remove existing IP config
                Remove-NetIPAddress -InterfaceAlias $selIface -Confirm:$false -ErrorAction SilentlyContinue
                Remove-NetRoute -InterfaceAlias $selIface -Confirm:$false -ErrorAction SilentlyContinue

                # Apply new IP
                New-NetIPAddress -InterfaceAlias $selIface -IPAddress $newIP -PrefixLength $newPrefix `
                    -DefaultGateway $(if($newGW -ne "n/a"){$newGW}else{$null}) -ErrorAction Stop | Out-Null

                # Apply DNS
                if($newDNS.Count -gt 0){
                    Set-DnsClientServerAddress -InterfaceAlias $selIface -ServerAddresses $newDNS -ErrorAction Stop
                }

                Write-ToUI "Static IP applied: $newIP/$newPrefix" "Lime"
                [Windows.Forms.MessageBox]::Show("Static IP applied successfully!","Done")
                $F.Close()
                Refresh-SystemInfo

            } catch {
                Write-ToUI "Static IP failed: $($_.Exception.Message)" "Orange"
                [Windows.Forms.MessageBox]::Show("Failed: $($_.Exception.Message)","Error")
            }
        })
        $F.Controls.Add($btnApply)

        # DHCP button
        $btnDHCP = New-Object Windows.Forms.Button
        $btnDHCP.Text="Switch to DHCP"
        $btnDHCP.Location="214,$($script:ry)"; $btnDHCP.Size="140,34"
        $btnDHCP.FlatStyle="Flat"; $btnDHCP.ForeColor=$btnAmb[1]; $btnDHCP.BackColor=$btnAmb[0]
        $btnDHCP.Font=New-Object Drawing.Font("Segoe UI",9,[Drawing.FontStyle]::Bold)
        $btnDHCP.FlatAppearance.BorderColor=$border; $btnDHCP.FlatAppearance.BorderSize=1
        $btnDHCP.Add_Click({
            $selAdapter = $adapters[$adCombo.SelectedIndex]
            $selIface   = $selAdapter.InterfaceAlias

            $confirm = [Windows.Forms.MessageBox]::Show(
                "Switch $selIface to DHCP (automatic)?",
                "Confirm DHCP","YesNo")
            if($confirm -ne "Yes"){return}

            try {
                Write-ToUI "Switching $selIface to DHCP..." "Cyan"
                Set-NetIPInterface -InterfaceAlias $selIface -Dhcp Enabled -ErrorAction Stop
                Set-DnsClientServerAddress -InterfaceAlias $selIface -ResetServerAddresses -ErrorAction Stop
                Write-ToUI "$selIface now using DHCP." "Lime"
                [Windows.Forms.MessageBox]::Show("Switched to DHCP successfully!","Done")
                $F.Close()
                Refresh-SystemInfo
            } catch {
                Write-ToUI "DHCP switch failed: $($_.Exception.Message)" "Orange"
                [Windows.Forms.MessageBox]::Show("Failed: $($_.Exception.Message)","Error")
            }
        })
        $F.Controls.Add($btnDHCP)

        $script:ry += 42
    }

    # Open Adapter Settings button — always present
    $btnSettings = New-Object Windows.Forms.Button
    $btnSettings.Text="Open Network Connections"
    $btnSettings.Location="16,$($script:ry)"; $btnSettings.Size="210,32"
    $btnSettings.FlatStyle="Flat"; $btnSettings.ForeColor=$btnBlue[1]; $btnSettings.BackColor=$btnBlue[0]
    $btnSettings.Font=New-Object Drawing.Font("Segoe UI",9,[Drawing.FontStyle]::Bold)
    $btnSettings.FlatAppearance.BorderColor=$border; $btnSettings.FlatAppearance.BorderSize=1
    $btnSettings.Add_Click({
        Start-Process "ncpa.cpl"
        $F.Close()
    })
    $F.Controls.Add($btnSettings)

    # Close button
    $btnClose = New-SubBtn $F "Close" 234 $($script:ry) 90 32 $btnDim
    $btnClose.Add_Click({$F.Close()})

    $F.Size="480,$($script:ry + 80)"
    $F.ShowDialog()
})
