$b7.Add_Click({
    [System.Media.SystemSounds]::Asterisk.Play()
    $DF = New-SubForm "Diagnostics & Hardware Tests" 480 380
    New-SubLbl $DF "Run hardware diagnostics and health checks" 15 12 440 18 $txtMuted 8|Out-Null

    $btnBat = New-SubBtn $DF "Battery Report" 15 45 440 36 $btnTeal
    $btnBat.Add_Click({
        Write-ToUI "Generating battery report..." "Cyan"
        $bp="$env:USERPROFILE\Desktop\battery-report.html"
        powercfg /batteryreport /output $bp 2>&1|Out-Null
        if(Test-Path $bp){Write-ToUI "Battery report saved to Desktop." "Lime"; Start-Process $bp}
        else{Write-ToUI "Battery report failed — device may not have a battery." "Orange"
             [Windows.Forms.MessageBox]::Show("Failed — device may not have a battery.","Error")}
    })

    $btnEnergy = New-SubBtn $DF "Energy Efficiency Report  (takes ~60 seconds)" 15 89 440 36 $btnTeal
    $btnEnergy.Add_Click({
        Write-ToUI "Running energy report (~60s)..." "Yellow"; $DF.Enabled=$false
        $ep="$env:USERPROFILE\Desktop\energy-report.html"
        powercfg /energy /output $ep /duration 60 2>&1|Out-Null; $DF.Enabled=$true
        if(Test-Path $ep){Write-ToUI "Energy report saved to Desktop." "Lime"; Start-Process $ep}
        else{Write-ToUI "Energy report failed." "Orange"}
    })

    $btnHealth = New-SubBtn $DF "System File Health Check  (DISM + SFC)" 15 133 440 36 $btnBlue
    $btnHealth.Add_Click({
        if([Windows.Forms.MessageBox]::Show("DISM + SFC can take 5-15 minutes. Continue?","Confirm","YesNo") -ne "Yes"){return}
        Write-ToUI "Running DISM..." "Yellow"; $DF.Enabled=$false
        DISM /Online /Cleanup-Image /ScanHealth 2>&1|Out-Null
        DISM /Online /Cleanup-Image /RestoreHealth 2>&1|Out-Null
        Write-ToUI "Running SFC..." "Yellow"
        sfc /scannow 2>&1|Out-Null; $DF.Enabled=$true
        Write-ToUI "Health check complete." "Lime"
        [Windows.Forms.MessageBox]::Show("Complete. Check console for details.","Done")
    })

    $btnMem = New-SubBtn $DF "Memory Diagnostic  (requires restart)" 15 177 440 36 $btnAmb
    $btnMem.Add_Click({
        if([Windows.Forms.MessageBox]::Show("Schedule memory test on next boot?","Confirm","YesNo") -eq "Yes"){
            Write-ToUI "Scheduling memory diagnostic..." "Yellow"; Start-Process "MdSched.exe"}
    })

    $btnDisk = New-SubBtn $DF "Disk Health Report  (SMART status)" 15 221 440 36 $btnBlue
    $btnDisk.Add_Click({
        Write-ToUI "Reading disk SMART data..." "Cyan"
        $disks=Get-PhysicalDisk|Select-Object FriendlyName,HealthStatus,OperationalStatus,MediaType,Size
        if($disks){
            $report="DISK HEALTH REPORT`n"+"="*50+"`n`n"
            foreach($d in $disks){
                $report+="Drive  : $($d.FriendlyName)`nType   : $($d.MediaType)`nSize   : $([math]::Round($d.Size/1GB,1)) GB`nHealth : $($d.HealthStatus)`nStatus : $($d.OperationalStatus)`n"+"-"*50+"`n"
            }
            $rp="$env:USERPROFILE\Desktop\disk-health.txt"
            $report|Out-File $rp -Encoding UTF8
            Write-ToUI "Disk report saved to Desktop." "Lime"; Start-Process "notepad.exe" $rp
        }else{Write-ToUI "No disks found." "Orange"}
    })

    $btnDriver = New-SubBtn $DF "Open Driver Verifier  (advanced)" 15 265 440 36 $btnRed
    $btnDriver.Add_Click({
        if([Windows.Forms.MessageBox]::Show("Driver Verifier can cause crashes if misused. Continue?","Warning","YesNo") -eq "Yes"){
            Start-Process "verifier.exe"}
    })

    $btnHW = New-SubBtn $DF "Hardware Info Dump  (CPU, RAM, GPU)" 15 309 440 36 $btnBlue
    $btnHW.Add_Click({
        Write-ToUI "Gathering hardware info..." "Cyan"
        $cpu=Get-CimInstance Win32_Processor|Select-Object Name,NumberOfCores,NumberOfLogicalProcessors,MaxClockSpeed
        $ram=Get-CimInstance Win32_PhysicalMemory|Measure-Object -Property Capacity -Sum
        $gpu=Get-CimInstance Win32_VideoController|Select-Object Name,DriverVersion,VideoModeDescription
        $report="HARDWARE INFO`n"+"="*60+"`n`nCPU`n"+"-"*60+"`n"
        $report+="Name   : $($cpu.Name)`nCores  : $($cpu.NumberOfCores)p / $($cpu.NumberOfLogicalProcessors)l`nSpeed  : $($cpu.MaxClockSpeed) MHz`n`n"
        $report+="RAM`n"+"-"*60+"`nTotal  : $([math]::Round($ram.Sum/1GB,2)) GB`n`nGPU`n"+"-"*60+"`n"
        foreach($g in $gpu){$report+="Name   : $($g.Name)`nDriver : $($g.DriverVersion)`nRes    : $($g.VideoModeDescription)`n"+"-"*60+"`n"}
        $rp="$env:USERPROFILE\Desktop\hardware-info.txt"
        $report|Out-File $rp -Encoding UTF8
        Write-ToUI "Hardware info saved to Desktop." "Lime"; Start-Process "notepad.exe" $rp
    })

    $DF.ShowDialog()
})

# ============================================================
# TOTAL DEPLOY
# ============================================================
$bAll.Add_Click({
    if([Windows.Forms.MessageBox]::Show(
        "TOTAL DEPLOY — full guided setup:`n`n  0. Rename computer`n  1. Create local account`n  2. Join domain`n  3. Activate Windows`n  4. Vendor Purge`n  5. System Sanitize`n  6. Install apps`n`nContinue?",
        "Total Deploy","YesNo") -ne "Yes"){return}
    [System.Media.SystemSounds]::Asterisk.Play()

    # Step 0 — Rename
    if([Windows.Forms.MessageBox]::Show("Rename this computer?`nCurrent: $($lblComputer.Text)","Step 0 — Rename","YesNo") -eq "Yes"){
        $RF = New-SubForm "Rename Computer" 380 115
        New-SubLbl $RF "New name (max 15 characters):" 15 15 340 18 $txtPrimary|Out-Null
        $tRen = New-SubTxt $RF 15 38 340; $tRen.Text=$lblComputer.Text; $tRen.SelectAll()
        $btnRen  = New-SubBtn $RF "Rename" 15 76 140 34 $btnBlue
        $btnSkipR= New-SubBtn $RF "Skip"   163 76 92  34 $btnDim
        $btnRen.Add_Click({
            $n=$tRen.Text.Trim()
            if([string]::IsNullOrWhiteSpace($n)-or $n-eq $lblComputer.Text){[Windows.Forms.MessageBox]::Show("Enter a different name.","No change");return}
            if($n.Length -gt 15){[Windows.Forms.MessageBox]::Show("Max 15 characters.","Too long");return}
            try{Rename-Computer -NewName $n -Force -ErrorAction Stop
                Write-ToUI "Computer renamed to '$n' — restart to apply." "Cyan"
                [Windows.Forms.MessageBox]::Show("Renamed. Will apply after restart.","Done")
                $RF.Close(); Refresh-SystemInfo
            }catch{[Windows.Forms.MessageBox]::Show("Failed: $($_.Exception.Message)","Error")}
        })
        $btnSkipR.Add_Click({$RF.Close()}); $RF.ShowDialog()
    }

    # Step 1 — Local Account
    if([Windows.Forms.MessageBox]::Show("Create a local account?","Step 1 — Local Account","YesNo") -eq "Yes"){
        $AF = New-SubForm "Create Local Account" 400 300
        New-SubLbl $AF "Username:" 15 15 360 18 $txtPrimary|Out-Null
        $tU = New-SubTxt $AF 15 35 360
        New-SubLbl $AF "Full Name (optional):" 15 70 360 18 $txtPrimary|Out-Null
        $tFN = New-SubTxt $AF 15 90 360
        New-SubLbl $AF "Password:" 15 125 360 18 $txtPrimary|Out-Null
        $tP1 = New-SubTxt $AF 15 145 360; $tP1.UseSystemPasswordChar=$true
        New-SubLbl $AF "Confirm Password:" 15 180 360 18 $txtPrimary|Out-Null
        $tP2 = New-SubTxt $AF 15 200 360; $tP2.UseSystemPasswordChar=$true
        $cbAdm = New-Object Windows.Forms.CheckBox
        $cbAdm.Text="Make this account a local Administrator"
        $cbAdm.Location="15,234"; $cbAdm.Size="360,20"
        $cbAdm.ForeColor=$txtPrimary; $cbAdm.BackColor=[Drawing.Color]::Transparent
        $cbAdm.Font=New-Object Drawing.Font("Segoe UI",9); $cbAdm.Checked=$true
        $AF.Controls.Add($cbAdm)
        $btnC    = New-SubBtn $AF "Create Account" 15 264 222 34 $btnTeal
        $btnSkip = New-SubBtn $AF "Skip"           245 264 130 34 $btnDim
        $btnC.Add_Click({
            $un=$tU.Text.Trim()
            if([string]::IsNullOrWhiteSpace($un)){[Windows.Forms.MessageBox]::Show("Username cannot be empty.","Error");return}
            if($tP1.Text -ne $tP2.Text){[Windows.Forms.MessageBox]::Show("Passwords don't match!","Error");return}
            if($tP1.Text.Length -lt 1){[Windows.Forms.MessageBox]::Show("Password cannot be empty.","Error");return}
            try{
                $sp=ConvertTo-SecureString $tP1.Text -AsPlainText -Force
                $p=@{Name=$un;Password=$sp;ErrorAction="Stop"}
                if(-not[string]::IsNullOrWhiteSpace($tFN.Text)){$p.FullName=$tFN.Text.Trim()}
                New-LocalUser @p|Out-Null
                if($cbAdm.Checked){Add-LocalGroupMember -Group "Administrators" -Member $un -ErrorAction Stop}
                else{Add-LocalGroupMember -Group "Users" -Member $un -ErrorAction Stop}
                Write-ToUI "Account '$un' created." "Lime"
                [Windows.Forms.MessageBox]::Show("Account '$un' created!","Done"); $AF.Close()
            }catch{[Windows.Forms.MessageBox]::Show("Failed: $($_.Exception.Message)","Error")}
        })
        $btnSkip.Add_Click({$AF.Close()}); $AF.ShowDialog()
    }

    # Step 2 — Domain Join
    if([Windows.Forms.MessageBox]::Show("Join a domain?","Step 2 — Domain Join","YesNo") -eq "Yes"){
        $DF2 = New-SubForm "Join Domain" 400 135
        New-SubLbl $DF2 "Domain Name:" 15 15 360 18 $txtPrimary|Out-Null
        $tDom = New-SubTxt $DF2 15 38 360
        $btnJ    = New-SubBtn $DF2 "Join Domain  (will reboot)" 15 78 222 34 $btnTeal
        $btnSkipD= New-SubBtn $DF2 "Skip"                       245 78 130 34 $btnDim
        $btnJ.Add_Click({
            if([string]::IsNullOrWhiteSpace($tDom.Text)){[Windows.Forms.MessageBox]::Show("Enter a domain name.","Error");return}
            if([Windows.Forms.MessageBox]::Show("Join '$($tDom.Text)' and reboot?`n`nTotal Deploy will not continue after reboot.","Confirm","YesNo") -eq "Yes"){
                try{Add-Computer -DomainName $tDom.Text -Restart -ErrorAction Stop}
                catch{[Windows.Forms.MessageBox]::Show("Failed: $($_.Exception.Message)")}}
        })
        $btnSkipD.Add_Click({$DF2.Close()}); $DF2.ShowDialog()
    }

    # Step 3 — Windows Activation
    if([Windows.Forms.MessageBox]::Show("Check and activate Windows?","Step 3 — Activation","YesNo") -eq "Yes"){
        $licStatus=(& cscript.exe "$env:SystemRoot\System32\slmgr.vbs" /dli 2>&1) -join " "
        if($licStatus -match "License Status: Licensed"){
            Write-ToUI "Windows is already activated." "Lime"
            [Windows.Forms.MessageBox]::Show("Windows is already activated.","Activation OK")
        } else {
            Write-ToUI "Windows not activated — prompting for key." "Orange"
            $KF = New-SubForm "Windows Activation" 400 145
            New-SubLbl $KF "Product Key:" 15 12 360 18 $txtPrimary|Out-Null
            New-SubLbl $KF "Format: XXXXX-XXXXX-XXXXX-XXXXX-XXXXX" 15 32 360 16 $txtMuted 8|Out-Null
            $tKey = New-SubTxt $KF 15 55 360
            $tKey.Font=New-Object Drawing.Font("Consolas",11); $tKey.CharacterCasing="Upper"
            # ===========================================================
            # DEFAULT KEY — change this line when the key changes
            # ===========================================================
            $tKey.Text="H3T4N-27DJJ-D2PMR-HY8BG-MKMM3"
            # ===========================================================
            $tKey.SelectAll()
            $btnAct  = New-SubBtn $KF "Activate Windows" 15 96 210 34 $btnTeal
            $btnSkipK= New-SubBtn $KF "Skip"             233 96 132 34 $btnDim
            $btnAct.Add_Click({
                $k=$tKey.Text.Trim()
                if($k -notmatch "^[A-Z0-9]{5}-[A-Z0-9]{5}-[A-Z0-9]{5}-[A-Z0-9]{5}-[A-Z0-9]{5}$"){
                    [Windows.Forms.MessageBox]::Show("Invalid key format.","Error");return}
                Write-ToUI "Installing product key..." "Cyan"
                & cscript.exe "$env:SystemRoot\System32\slmgr.vbs" /ipk $k 2>&1|Out-Null
                Write-ToUI "Activating..." "Cyan"
                & cscript.exe "$env:SystemRoot\System32\slmgr.vbs" /ato 2>&1|Out-Null
                Write-ToUI "Activation complete." "Lime"
                [Windows.Forms.MessageBox]::Show("Key applied.","Done"); $KF.Close()
            })
            $btnSkipK.Add_Click({$KF.Close()}); $KF.ShowDialog()
        }
    }

    # Steps 4-6 — automated (disable buttons while running)
    foreach($btn in @($bAll,$b1,$b2,$b3,$b4,$b5,$b6,$b7)){$btn.Enabled=$false}
    $bAll.Text="  Running..."

    Write-ToUI "=== STEP 4: VENDOR PURGE ===" "Yellow"
    Run-VendorPurge

    Write-ToUI "=== STEP 5: SYSTEM SANITIZE ===" "Yellow"
    Run-Debloat; Run-EssentialTweaks

    Write-ToUI "=== STEP 6: APP INSTALL ===" "Yellow"
    Show-AppPicker{
        param($sel,$chrome,$vlc)
        Run-Installs $sel $chrome $vlc
        Write-ToUI "=== TOTAL DEPLOY COMPLETE — PLEASE RESTART ===" "Yellow"
        [System.Media.SystemSounds]::Exclamation.Play()
        [Windows.Forms.MessageBox]::Show("Total Deploy complete!`n`nA restart is recommended.","Complete!")
        Refresh-SystemInfo
        $bAll.Text="  TOTAL DEPLOY — Full Provision"
        foreach($btn in @($bAll,$b1,$b2,$b3,$b4,$b5,$b6,$b7)){$btn.Enabled=$true}
    }
})

$Form.ShowDialog()
