function Write-ToUI($msg,$col="Lime"){
    $ConsoleOutput.SelectionStart  = $ConsoleOutput.TextLength
    $ConsoleOutput.SelectionLength = 0
    $ConsoleOutput.SelectionColor  = [System.Drawing.Color]::$col
    $ConsoleOutput.AppendText("[$((Get-Date).ToString('HH:mm:ss'))] $msg`r`n")
    $ConsoleOutput.ScrollToCaret()
    $Form.Refresh()
}

