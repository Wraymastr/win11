        $scroll.Controls.Add($cb); $script:ay+=22; $cbs[$id]=$cb
    }

    # -------------------------------------------------------
    # CRITICAL — always on by default
    # -------------------------------------------------------
    AP-Section "CRITICAL  (ticked by default)"
    AP-Check "Microsoft 365 Desktop Suite" "Microsoft.Office"                $true
    AP-Check "Google Chrome"               "Google.Chrome"                   $true
    AP-Check "Mozilla Firefox"             "Mozilla.Firefox"                 $true
    AP-Check "Google Drive"                "Google.GoogleDrive"              $true
    AP-Check "VLC Media Player"            "VideoLAN.VLC"                    $true
    AP-Check "7-Zip"                       "7zip.7zip"                       $true
    AP-Check "Adobe Acrobat Reader"        "Adobe.Acrobat.Reader.64-bit"     $true

    $script:ay += 6
    # -------------------------------------------------------
    # OPTIONAL — off by default
    # -------------------------------------------------------
    AP-Section "OPTIONAL  (unticked by default)"
    AP-Check "LocalSend"                   "LocalSend.LocalSend"             $false
    AP-Check "CrystalDiskInfo"             "CrystalDewWorld.CrystalDiskInfo" $false
    AP-Check "Angry IP Scanner"            "Angryziber.AngryIPScanner"       $false
    AP-Check "Everything  (fast search)"   "voidtools.Everything"            $false
    AP-Check "HP Support Assistant"        "HP.HPSupportAssistant"           $false
    AP-Check "Malwarebytes"                "Malwarebytes.Malwarebytes"       $false
    AP-Check "Winaero Tweaker"             "WinAero.WinaeroTweaker"          $false
    AP-Check "O&O ShutUp10  (privacy)"     "OOSU10"                          $false
    AP-Check "PowerToys"                   "Microsoft.PowerToys"             $false
    AP-Check "Process Explorer"            "Microsoft.Sysinternals.ProcessExplorer" $false
    AP-Check "Bulk Crap Uninstaller"       "Klocman.BulkCrapUninstaller"     $false
    AP-Check "Autoruns"                    "Microsoft.Sysinternals.Autoruns" $false
    AP-Check "K-Lite Codec Pack Standard"  "CodecGuide.K-LiteCodecPack.Standard" $false

    $script:ay += 8
    AP-Section "SET AS DEFAULT"

    $cbCD=New-Object Windows.Forms.CheckBox; $cbCD.Text="Set Chrome as default browser"
    $cbCD.Location="18,$($script:ay)"; $cbCD.Size="360,20"
    $cbCD.ForeColor=$txtPrimary; $cbCD.BackColor=[Drawing.Color]::Transparent
    $cbCD.Font=New-Object Drawing.Font("Segoe UI",9); $cbCD.Checked=$true
