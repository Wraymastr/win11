$bannerTimer=New-Object Windows.Forms.Timer
$bannerTimer.Interval=18
$bannerTimer.Add_Tick({
    if($bannerIndex -lt $bannerLines.Count){
        $line=$bannerLines[$bannerIndex]
        if($bannerIndex -ge 1 -and $bannerIndex -le 4){$lc="Cyan"}
        elseif($line -match "CHANGELOG|QUICK REFERENCE|COMMANDS"){$lc="White"}
        elseif($line -match "^\s{2}\+"){$lc="Gray"}
        elseif($line -match ">"){$lc="Yellow"}
        elseif($line -match "READY"){$lc="Lime"}
        else{$lc="Gray"}
        Write-ToUI $line $lc
        $script:bannerIndex++
    } else {$bannerTimer.Stop()}
})
$script:bannerIndex=0
$bannerTimer.Start()

