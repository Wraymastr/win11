    [System.Media.SystemSounds]::Asterisk.Play()
    Show-DomainTools
})

$b6.Add_Click({
    [System.Media.SystemSounds]::Asterisk.Play()
    $DF=New-SubForm "Diagnostics & Hardware Tests" 480 420
    New-SubLbl $DF "Run hardware diagnostics and health checks" 15 12 440 18 $txtMuted 8|Out-Null

    $btnBat=New-SubBtn $DF "Battery Report" 15 45 440 36 $btnTeal
    $btnBat.Add_Click({
        Write-ToUI "Generating battery report..." "Cyan"
        $bp="$env:USERPROFILE\Desktop\battery-report.html"
        powercfg /batteryreport /output $bp 2>&1|Out-Null
        if(Test-Path $bp){Write-ToUI "Battery report saved to Desktop." "Lime"; Start-Process $bp}
        else{Write-ToUI "Battery report failed." "Orange"
             [Windows.Forms.MessageBox]::Show("Failed — device may not have a battery.","Error")}
    })

    $btnEnergy=New-SubBtn $DF "Energy Efficiency Report  (takes ~60 seconds)" 15 89 440 36 $btnTeal
    $btnEnergy.Add_Click({
        Write-ToUI "Running energy report (~60s)..." "Yellow"; $DF.Enabled=$false
        $ep="$env:USERPROFILE\Desktop\energy-report.html"
        powercfg /energy /output $ep /duration 60 2>&1|Out-Null; $DF.Enabled=$true
        if(Test-Path $ep){Write-ToUI "Energy report saved to Desktop." "Lime"; Start-Process $ep}
        else{Write-ToUI "Energy report failed." "Orange"}
    })

    $btnHealth=New-SubBtn $DF "System File Health Check  (DISM + SFC)" 15 133 440 36 $btnBlue
    $btnHealth.Add_Click({
        if([Windows.Forms.MessageBox]::Show("DISM + SFC can take 5-15 minutes.`nContinue?","Confirm","YesNo") -ne "Yes"){return}
        Write-ToUI "Running DISM..." "Yellow"; $DF.Enabled=$false
        DISM /Online /Cleanup-Image /ScanHealth 2>&1|Out-Null
        DISM /Online /Cleanup-Image /RestoreHealth 2>&1|Out-Null
        Write-ToUI "Running SFC..." "Yellow"
        sfc /scannow 2>&1|Out-Null; $DF.Enabled=$true
        Write-ToUI "Health check complete." "Lime"
        [Windows.Forms.MessageBox]::Show("Complete.","Done")
    })

    $btnMem=New-SubBtn $DF "Memory Diagnostic  (requires restart)" 15 177 440 36 $btnAmb
    $btnMem.Add_Click({
        if([Windows.Forms.MessageBox]::Show("Schedule memory test on next boot?","Confirm","YesNo") -eq "Yes"){
            Write-ToUI "Scheduling memory diagnostic..." "Yellow"; Start-Process "MdSched.exe"}
    })

    $btnDisk=New-SubBtn $DF "Disk Health Report  (SMART status)" 15 221 440 36 $btnBlue
    $btnDisk.Add_Click({
        Write-ToUI "Reading disk SMART data..." "Cyan"
        $disks=Get-PhysicalDisk|Select-Object FriendlyName,HealthStatus,OperationalStatus,MediaType,Size
        if($disks){
            $report="DISK HEALTH REPORT`n"+"="*50+"`n`n"
            foreach($d in $disks){
                $sizeGB=[math]::Round($d.Size/1GB,1)
                $report+="Drive  : $($d.FriendlyName)`nType   : $($d.MediaType)`nSize   : $sizeGB GB`nHealth : $($d.HealthStatus)`nStatus : $($d.OperationalStatus)`n"+"-"*50+"`n"
            }
            $rp="$env:USERPROFILE\Desktop\disk-health.txt"
            $report|Out-File $rp -Encoding UTF8
            Write-ToUI "Disk report saved to Desktop." "Lime"; Start-Process "notepad.exe" $rp
        }else{Write-ToUI "No disks found." "Orange"}
    })

    $btnDriver=New-SubBtn $DF "Open Driver Verifier  (advanced)" 15 265 440 36 $btnRed
    $btnDriver.Add_Click({
        if([Windows.Forms.MessageBox]::Show("Driver Verifier can cause crashes if misused.`nContinue?","Warning","YesNo") -eq "Yes"){
            Start-Process "verifier.exe"}
    })

    $btnHW=New-SubBtn $DF "Hardware Info Dump  (CPU, RAM, GPU)" 15 309 440 36 $btnBlue
    $btnHW.Add_Click({
        Write-ToUI "Gathering hardware info..." "Cyan"
        $cpu=Get-CimInstance Win32_Processor|Select-Object Name,NumberOfCores,NumberOfLogicalProcessors,MaxClockSpeed
        $ram=Get-CimInstance Win32_PhysicalMemory|Measure-Object -Property Capacity -Sum
        $gpu=Get-CimInstance Win32_VideoController|Select-Object Name,DriverVersion,VideoModeDescription
        $report="HARDWARE INFO`n"+"="*60+"`n`nCPU`n"+"-"*60+"`n"
        $report+="Name   : $($cpu.Name)`nCores  : $($cpu.NumberOfCores) physical / $($cpu.NumberOfLogicalProcessors) logical`nSpeed  : $($cpu.MaxClockSpeed) MHz`n`n"
        $report+="RAM`n"+"-"*60+"`nTotal  : $([math]::Round($ram.Sum/1GB,2)) GB`n`nGPU`n"+"-"*60+"`n"
        foreach($g in $gpu){$report+="Name   : $($g.Name)`nDriver : $($g.DriverVersion)`nRes    : $($g.VideoModeDescription)`n"+"-"*60+"`n"}
        $rp="$env:USERPROFILE\Desktop\hardware-info.txt"
        $report|Out-File $rp -Encoding UTF8
        Write-ToUI "Hardware info saved to Desktop." "Lime"; Start-Process "notepad.exe" $rp
    })

    $btnClose=New-SubBtn $DF "Close" 15 353 100 30 $btnDim
    $btnClose.Add_Click({$DF.Close()})
    $DF.ShowDialog()
})

